#!/bin/bash

# Pipe stdin to a browser. Infers filetype from content or -t flag.
#   echo '<h1>hi</h1>' | bcat
#   cat data.json | bcat -t json
#   cat README.md | bcat -t md
#   bcat < style.css

set -euo pipefail

ext="html"
while getopts "t:" opt; do
  case $opt in
    t) ext="$OPTARG" ;;
    *) echo "usage: bcat [-t ext] < file" >&2; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

# Stable scratch dir so we don't leak a fresh mktemp -d on every invocation.
# Prune files older than an hour to keep it bounded without clobbering files
# a browser tab may still be reading from a recent call.
dir="${TMPDIR:-/tmp}/bcat"
mkdir -p "$dir"
find "$dir" -type f -mmin +60 -delete 2>/dev/null || true

path="$dir/bcat-$$-${RANDOM}.$ext"
cat - > "$path"

if [ "$(uname -s)" = Darwin ]; then
  open "$path"
else
  xdg-open "$path" 2>/dev/null || echo "$path"
fi
