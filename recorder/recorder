  font-size: 14px;
  font-style: italic;
}

/* Disable browser's default scroll anchoring so it doesn't fight our
   bottom-tracking scroll-follower (MDN: when DOM appends below viewport,
   default `auto` tries to PRESERVE position, which we don't want when
   the user is following live). */
html { overflow-anchor: none; }
.transcript { overflow-anchor: none; }

.jump {
  position: fixed;
  bottom: 1.5rem; left: 50%; transform: translateX(-50%);
  background: var(--accent); color: var(--bg);
  padding: 0.55rem 1.15rem;
  border-radius: 999px;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 13px; font-weight: 600;
  border: none; cursor: pointer;
  box-shadow: var(--shadow);
  opacity: 0; pointer-events: none;
  transition: opacity 0.2s;
  display: inline-flex; align-items: center; gap: 0.5em;
}
.jump.visible { opacity: 1; pointer-events: auto; }
.jump .badge {
  background: rgba(0, 0, 0, 0.15);
  border-radius: 999px;
  padding: 0 0.5em;
  font-variant-numeric: tabular-nums;
  font-size: 12px;
}
.jump .badge:empty { display: none; }

/* Speech-rate indicator (when transcription rate exceeds safe reading
   speed of ~160 wpm, the user is falling behind). Shown only when active. */
.rate-warn {
  display: none; /* shown by JS when fast */
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 11.5px; color: var(--accent);
  letter-spacing: 0.04em;
}
.rate-warn.visible { display: inline-flex; }

/* ------- modal ------- */
.modal-backdrop {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: none; align-items: center; justify-content: center;
  z-index: 100;
}
.modal-backdrop.visible { display: flex; }
.modal {
  background: var(--bg-elev);
  border: 1px solid var(--rule-strong);
  border-radius: 10px;
  padding: 1.5rem;
  max-width: 28rem;
  box-shadow: var(--shadow);
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}
.modal h2 { margin: 0 0 0.5rem; font-size: 16px; font-weight: 600; }
.modal p { margin: 0 0 1.25rem; font-size: 14px; color: var(--fg-mute); line-height: 1.5; }
.modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }

/* ------- audio level meter ------- */
.meter {
  display: inline-flex; align-items: center; gap: 3px;
  height: 14px; margin-left: 0.5em;
  vertical-align: middle;
}
.meter .bar {
  width: 3px; height: 100%; border-radius: 1px;
  background: var(--rule-strong);
  transition: background 80ms linear;
}
.meter.silent .bar { background: var(--rule); }

/* ------- connection state ------- */
.conn {
  display: inline-flex; align-items: center; gap: 0.4em;
  font-size: 11.5px; color: var(--fg-mute);
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}
.conn .conn-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #2a8c4a;
}
.conn.disconnected .conn-dot {
  background: var(--pill-rec); animation: pulse 0.9s ease-in-out infinite;
}
.conn.disconnected { color: var(--pill-rec); }

/* ------- in-page search ------- */
.find-bar {
  position: fixed; top: 1rem; right: 1rem;
  background: var(--bg-elev); border: 1px solid var(--rule-strong);
  border-radius: 8px; padding: 0.4rem 0.5rem;
  box-shadow: var(--shadow);
  display: none; align-items: center; gap: 0.5rem;
  z-index: 90;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 13px;
}
.find-bar.visible { display: flex; }
.find-bar input {
  border: none; outline: none; background: transparent; color: var(--fg);
  font: inherit; width: 18ch; padding: 0.2em 0.3em;
  font-family: inherit;
}
.find-bar .find-count {
  color: var(--fg-faint); font-variant-numeric: tabular-nums;
  font-size: 12px; min-width: 4ch; text-align: right;
}
.find-bar .find-btn {
  background: transparent; border: 1px solid var(--rule);
  border-radius: 4px; cursor: pointer; padding: 0.1em 0.45em;
  color: var(--fg-mute); font-size: 12px;
}
.find-bar .find-btn:hover { background: var(--btn-hover); color: var(--fg); }
mark.find-hit {
  background: rgba(224, 163, 92, 0.3); color: inherit;
  border-radius: 2px; padding: 0 1px;
}
mark.find-hit.current {
  background: var(--accent); color: var(--bg);
}

/* ------- TOC ------- */
.toc {
  margin: 0 0 2rem; padding: 0.85rem 1rem;
  border: 1px solid var(--rule);
  border-radius: 7px;
  background: var(--bg-elev);
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 12.5px;
}
.toc summary {
  cursor: pointer; color: var(--fg-mute); font-weight: 600;
  letter-spacing: 0.04em; text-transform: uppercase;
  outline: none;
  list-style: none;
  display: flex; align-items: center; gap: 0.5em;
}
.toc summary::-webkit-details-marker { display: none; }
.toc summary::before {
  content: "▸"; transition: transform 0.15s; display: inline-block;
}
.toc[open] summary::before { transform: rotate(90deg); }
.toc-list {
  margin: 0.6rem 0 0; padding: 0; list-style: none;
  display: grid; grid-template-columns: auto 1fr; gap: 0.25em 0.85em;
  font-variant-numeric: tabular-nums;
}
.toc-list a {
  color: var(--accent); text-decoration: none;
}
.toc-list a:hover { text-decoration: underline; }
.toc-list .ts { color: var(--fg-mute); }
.toc-list .user-mark { color: var(--pill-rec); font-weight: 600; }
.toc-empty { color: var(--fg-faint); font-style: italic; }

/* ------- help overlay ------- */
.help {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.55);
  display: none; align-items: center; justify-content: center;
  z-index: 110;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}
.help.visible { display: flex; }
.help-card {
  background: var(--bg-elev); color: var(--fg);
  border: 1px solid var(--rule-strong); border-radius: 10px;
  padding: 1.5rem 1.75rem;
  max-width: 32rem; width: calc(100vw - 2rem);
  box-shadow: var(--shadow);
}
.help-card h2 { margin: 0 0 1rem; font-size: 15px; font-weight: 600; }
.help-card kbd {
  display: inline-block; min-width: 1.5em; text-align: center;
  font-family: ui-monospace, SF Mono, Menlo, monospace; font-size: 11.5px;
  border: 1px solid var(--rule-strong); border-radius: 4px;
  padding: 0.05em 0.4em; margin-right: 0.6em;
  background: var(--bg); color: var(--fg);
}
.help-card dl { margin: 0; display: grid; grid-template-columns: auto 1fr; gap: 0.5em 1em; font-size: 13px; }
.help-card dt { white-space: nowrap; }
.help-card dd { margin: 0; color: var(--fg-mute); }
.help-card .dismiss {
  margin-top: 1.25rem; font-size: 12px; color: var(--fg-faint);
  text-align: center;
}

/* ------- focus + reduced motion ------- */
.btn:focus-visible, .find-btn:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
.toc summary:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
  border-radius: 3px;
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

@media (max-width: 640px) {
  .frame { padding: 1.5rem 1rem 9rem; }
  body { font-size: 17px; }
  header { grid-template-columns: 1fr; }
  .pill { justify-self: start; }
  .find-bar { right: 0.5rem; left: 0.5rem; top: 0.5rem; }
  .find-bar input { width: 100%; flex: 1; }
}
</style>
</head>
<body>
<div class="frame">
  <header>
    <div class="title-block">
      <div class="name" id="name">…</div>
      <div class="meta-row">
        <span class="meta"><span class="label">started</span><span class="val" id="started">—</span></span>
        <span class="meta"><span class="label">audio</span><span class="val" id="duration">00:00:00</span></span>
        <span class="meta"><span class="label">wall</span><span class="val" id="wall-duration">00:00:00</span></span>
        <span class="meta"><span class="label">input</span><span class="val" id="device">—</span></span>
        <span class="meta" id="meta-polish" hidden><span class="label">polish</span><span class="val" id="polish-state">—</span></span>
        <span class="rate-warn" id="rate-warn" title="speech rate is above ~160 wpm — you may fall behind on reading">⚠ fast speech</span>
        <span class="conn" id="conn" title="server connection state">
          <span class="conn-dot"></span><span id="conn-text">live</span>
        </span>
      </div>
    </div>
    <span class="pill" id="status">
      <span class="dot"></span><span id="status-text">starting</span>
      <span class="meter silent" id="meter" aria-hidden="true">
        <span class="bar"></span><span class="bar"></span><span class="bar"></span>
        <span class="bar"></span><span class="bar"></span><span class="bar"></span>
        <span class="bar"></span><span class="bar"></span><span class="bar"></span>
      </span>
    </span>
    <div class="toolbar ui">
      <button class="btn primary" id="btn-copy" title="Copy full transcript (C)">
        copy<span class="kbd">C</span>
      </button>
      <button class="btn" id="btn-mark" title="Mark this moment with a timestamp (M)">
        mark<span class="kbd">M</span>
      </button>
      <button class="btn" id="btn-toggle-raw" hidden title="Show raw transcript instead of polished (R)" aria-pressed="false">
        raw<span class="kbd">R</span>
      </button>
      <button class="btn" id="btn-find" title="Find in transcript (/)">
        find<span class="kbd">/</span>
      </button>
      <button class="btn" id="btn-help" title="Keyboard shortcuts (?)" aria-label="help">
        ?
      </button>
      <button class="btn danger" id="btn-stop" title="Stop recording and finalize files (S)">
        stop<span class="kbd">S</span>
      </button>
    </div>
  </header>

  <div class="warning" id="warning" hidden></div>

  <div class="paths ui" id="paths"></div>

  <details class="toc ui" id="toc" hidden>
    <summary>markers <span class="meta" id="toc-count" style="text-transform: none; letter-spacing: 0; font-weight: 400;"></span></summary>
    <ol class="toc-list" id="toc-list"></ol>
  </details>

  <main class="transcript" id="transcript"
        role="log" aria-live="polite" aria-atomic="false"
        aria-relevant="additions text" aria-label="meeting transcript">
    <div class="empty">Waiting for the first words…</div>
  </main>
</div>

<div class="find-bar ui" id="find-bar" role="search">
  <input id="find-input" type="text" placeholder="find in transcript" aria-label="find in transcript" autocomplete="off" />
  <span class="find-count" id="find-count">0/0</span>
  <button class="find-btn" id="find-prev" title="previous match (Shift+Enter)" aria-label="previous">↑</button>
  <button class="find-btn" id="find-next" title="next match (Enter)" aria-label="next">↓</button>
  <button class="find-btn" id="find-close" title="close (Esc)" aria-label="close">✕</button>
</div>

<button class="jump" id="jump" aria-label="jump to live tail">
  <span>↓ jump to live</span>
  <span class="badge" id="jump-badge"></span>
</button>
<div class="toast ui" id="toast">copied</div>

<div class="help" id="help" role="dialog" aria-modal="true" aria-labelledby="help-title">
  <div class="help-card">
    <h2 id="help-title">Keyboard shortcuts</h2>
    <dl>
      <dt><kbd>C</kbd></dt><dd>copy full transcript to clipboard</dd>
      <dt><kbd>M</kbd></dt><dd>add a timestamped mark at this moment</dd>
      <dt><kbd>R</kbd></dt><dd>toggle raw / polished view (when polish is on)</dd>
      <dt><kbd>J</kbd></dt><dd>jump to the live tail</dd>
      <dt><kbd>S</kbd></dt><dd>stop recording (with confirmation)</dd>
      <dt><kbd>/</kbd></dt><dd>find in transcript</dd>
      <dt><kbd>?</kbd></dt><dd>show this help</dd>
      <dt><kbd>Esc</kbd></dt><dd>close find / help / dialog</dd>
    </dl>
    <div class="dismiss">click anywhere or press Esc to dismiss</div>
  </div>
</div>

<div class="modal-backdrop" id="modal" role="dialog" aria-modal="true">
  <div class="modal">
    <h2>Stop recording?</h2>
    <p>This will end the recording and finalize the transcript files. The audio backup will remain playable.</p>
    <div class="modal-actions">
      <button class="btn" id="modal-cancel">cancel</button>
      <button class="btn danger" id="modal-confirm">stop recording</button>
    </div>
  </div>
</div>

<script>
(function () {
  const $ = (id) => document.getElementById(id);
  const transcript = $('transcript');
  const jump = $('jump');
  const toast = $('toast');
  const modal = $('modal');
  const helpEl = $('help');
  const findBar = $('find-bar');
  const findInput = $('find-input');
  const conn = $('conn');
  const meterEl = $('meter');
  const meterBars = meterEl ? meterEl.querySelectorAll('.bar') : [];
  let following = true;
  let lastScrollY = window.scrollY;
  let lastState = null;
  let pathsRendered = false;
  let showRaw = false;
  let firstStateReceived = false;
  // Track segments seen at the moment the user scrolled away from the
  // bottom; the delta is the "unread" badge.
  let segmentsAtScrollBreak = 0;

  // ---- viewport / scroll-following -----------------------------------------

  function isAtBottom() {
    return (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 80;
  }
  window.addEventListener('scroll', () => {
    const dy = window.scrollY - lastScrollY;
    lastScrollY = window.scrollY;
    if (dy < 0 && !isAtBottom()) {
      if (following) {
        // user just scrolled away from the live tail — pin a baseline so
        // we can show the "↓ N new lines" badge for content that arrives
        // after this point.
        segmentsAtScrollBreak = lastState ? (lastState.segments || []).length : 0;
      }
      following = false;
    }
    if (isAtBottom()) {
      following = true;
      segmentsAtScrollBreak = 0;
      updateJumpBadge();
    }
    jump.classList.toggle('visible', !following);
  });
  jump.addEventListener('click', goLive);
  function goLive() {
    following = true;
    segmentsAtScrollBreak = 0;
    updateJumpBadge();
    window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
  }
  function updateJumpBadge() {
    const badge = $('jump-badge');
    if (!badge) return;
    if (following || !lastState) { badge.textContent = ''; return; }
    const now = (lastState.segments || []).length;
    const newSegs = Math.max(0, now - segmentsAtScrollBreak);
    badge.textContent = newSegs > 0 ? `+${newSegs}` : '';
  }

  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('visible');
    clearTimeout(showToast._t);
    showToast._t = setTimeout(() => toast.classList.remove('visible'), 1600);
  }

  // ---- transcript view (raw / polished) ------------------------------------

  function viewSegments(state) {
    const segs = state.segments || [];
    const polished = state.polished_segments || [];
    if (showRaw || polished.length === 0) {
      return segs.map(s => ({ t: s.t, text: s.text, raw: s.text }));
    }
    const out = [];
    let i = 0, pi = 0;
    while (i < segs.length) {
      const p = polished[pi];
      if (p && i >= p.raw_start_index && i < p.raw_end_index) {
        out.push({ t: segs[p.raw_start_index].t, text: p.text, raw: p.raw });
        i = p.raw_end_index; pi++;
      } else {
        out.push({ t: segs[i].t, text: segs[i].text, raw: segs[i].text });
        i++;
      }
    }
    return out;
  }

  function plainTranscript(state) {
    const segViews = viewSegments(state);
    const markers = state.markers || [];
    let out = ''; let mi = 0; let buf = [];
    const flush = () => { if (buf.length) { out += buf.join(' ').trim() + '\n\n'; buf = []; } };
    for (const sv of segViews) {
      while (mi < markers.length && markers[mi].t <= sv.t) {
        flush(); out += markers[mi].label + '\n\n'; mi++;
      }
      buf.push(sv.text.trim());
    }
    flush();
    while (mi < markers.length) { out += markers[mi].label + '\n\n'; mi++; }
    if (state.draft) out += '… ' + state.draft.trim();
    return out.trim();
  }

  // ---- buttons --------------------------------------------------------------

  $('btn-copy').addEventListener('click', async () => {
    if (!lastState) return;
    try {
      await navigator.clipboard.writeText(plainTranscript(lastState));
      showToast('copied transcript');
    } catch {
      showToast('clipboard denied — try ⌘A then ⌘C in the page');
    }
  });

  $('btn-mark').addEventListener('click', async () => {
    try {
      const r = await fetch('/control/mark', { method: 'POST' });
      if (r.ok) showToast('mark added');
      else showToast('mark failed');
    } catch { showToast('mark failed'); }
  });

  const stopBtn = $('btn-stop');
  stopBtn.addEventListener('click', () => modal.classList.add('visible'));
  $('modal-cancel').addEventListener('click', () => modal.classList.remove('visible'));
  $('modal-confirm').addEventListener('click', async () => {
    modal.classList.remove('visible');
    stopBtn.disabled = true;
    try {
      await fetch('/control/stop', { method: 'POST' });
      showToast('stopping…');
    } catch { showToast('stop request failed'); stopBtn.disabled = false; }
  });

  $('btn-toggle-raw').addEventListener('click', () => {
    showRaw = !showRaw;
    const btn = $('btn-toggle-raw');
    btn.setAttribute('aria-pressed', showRaw ? 'true' : 'false');
    btn.classList.toggle('primary', showRaw);
    btn.firstChild.textContent = showRaw ? 'polished' : 'raw';
    if (lastState) render(lastState);
  });

  // ---- help overlay --------------------------------------------------------

  $('btn-help').addEventListener('click', () => helpEl.classList.add('visible'));
  helpEl.addEventListener('click', () => helpEl.classList.remove('visible'));

  // ---- in-page find --------------------------------------------------------

  let findHits = [];     // array of {node, start, end}
  let findCurrent = -1;
  let findActive = false;

  function openFind() {
    findBar.classList.add('visible');
    findActive = true;
    findInput.focus();
    findInput.select();
  }
  function closeFind() {
    findBar.classList.remove('visible');
    findActive = false;
    clearFindHighlights();
  }
  function clearFindHighlights() {
    transcript.querySelectorAll('mark.find-hit').forEach(m => {
      const text = document.createTextNode(m.textContent);
      m.parentNode.replaceChild(text, m);
    });
    transcript.normalize();
    findHits = [];
    findCurrent = -1;
    $('find-count').textContent = '0/0';
  }

  function runFind(query) {
    clearFindHighlights();
    if (!query || query.length < 2) return;
    const q = query.toLowerCase();
    // Walk text nodes only (skip script/style/already-marked).
    const walker = document.createTreeWalker(
      transcript, NodeFilter.SHOW_TEXT,
      { acceptNode: n => n.nodeValue && n.nodeValue.trim()
          ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT }
    );
    const nodes = [];
    let n;
    while ((n = walker.nextNode())) nodes.push(n);
    for (const node of nodes) {
      const lc = node.nodeValue.toLowerCase();
      let from = 0;
      const ranges = [];
      while (true) {
        const idx = lc.indexOf(q, from);
        if (idx === -1) break;
        ranges.push([idx, idx + q.length]);
        from = idx + q.length;
      }
      if (!ranges.length) continue;
      // Replace this text node with a sequence of text + <mark> nodes
      const frag = document.createDocumentFragment();
      let cursor = 0;
      for (const [s, e] of ranges) {
        if (s > cursor) frag.appendChild(document.createTextNode(node.nodeValue.slice(cursor, s)));
        const mk = document.createElement('mark');
        mk.className = 'find-hit';
        mk.textContent = node.nodeValue.slice(s, e);
        frag.appendChild(mk);
        findHits.push(mk);
        cursor = e;
      }
      if (cursor < node.nodeValue.length) frag.appendChild(document.createTextNode(node.nodeValue.slice(cursor)));
      node.parentNode.replaceChild(frag, node);
    }
    if (findHits.length) {
      findCurrent = 0;
      activateFindHit();
    } else {
      $('find-count').textContent = '0/0';
    }
  }

  function activateFindHit() {
    findHits.forEach((m, i) => m.classList.toggle('current', i === findCurrent));
    if (findCurrent >= 0 && findHits[findCurrent]) {
      findHits[findCurrent].scrollIntoView({ block: 'center', behavior: 'smooth' });
      following = false;
    }
    $('find-count').textContent = findHits.length
      ? `${findCurrent + 1}/${findHits.length}` : '0/0';
  }

  function findStep(dir) {
    if (!findHits.length) return;
    findCurrent = (findCurrent + dir + findHits.length) % findHits.length;
    activateFindHit();
  }

  $('btn-find').addEventListener('click', openFind);
  $('find-close').addEventListener('click', closeFind);
  $('find-next').addEventListener('click', () => findStep(1));
  $('find-prev').addEventListener('click', () => findStep(-1));
  findInput.addEventListener('input', () => runFind(findInput.value));
  findInput.addEventListener('keydown', e => {
    if (e.key === 'Escape') { e.preventDefault(); closeFind(); }
    else if (e.key === 'Enter') {
      e.preventDefault();
      findStep(e.shiftKey ? -1 : 1);
    }
  });

  // ---- keyboard shortcuts (global) -----------------------------------------

  document.addEventListener('keydown', (e) => {
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const tag = (e.target && e.target.tagName) || '';
    const inField = tag === 'INPUT' || tag === 'TEXTAREA';

    if (e.key === 'Escape') {
      if (helpEl.classList.contains('visible')) {
        helpEl.classList.remove('visible'); e.preventDefault(); return;
      }
      if (modal.classList.contains('visible')) {
        modal.classList.remove('visible'); e.preventDefault(); return;
      }
      if (findActive) { closeFind(); e.preventDefault(); return; }
    }
    if (inField) return;
    if (modal.classList.contains('visible')) return;
    if (helpEl.classList.contains('visible')) return;

    if (e.key === '/') { e.preventDefault(); openFind(); return; }
    if (e.key === '?') { e.preventDefault(); helpEl.classList.add('visible'); return; }

    const k = e.key.toLowerCase();
    if (k === 'c') { e.preventDefault(); $('btn-copy').click(); }
    else if (k === 'm') { e.preventDefault(); $('btn-mark').click(); }
    else if (k === 's') { e.preventDefault(); stopBtn.click(); }
    else if (k === 'j') { e.preventDefault(); goLive(); }
    else if (k === 'r' && !$('btn-toggle-raw').hidden) {
      e.preventDefault(); $('btn-toggle-raw').click();
    }
  });

  // ---- audio level meter ---------------------------------------------------

  function updateMeter(peakDb) {
    if (!meterBars.length) return;
    // Map dBFS to bar count: -60 = 0 bars, -3 = 9 bars (clipping warn).
    const norm = Math.max(0, Math.min(1, (peakDb + 60) / 57));
    const lit = Math.round(norm * meterBars.length);
    meterEl.classList.toggle('silent', lit === 0);
    meterBars.forEach((b, i) => {
      if (i < lit) {
        // Color ramp: green -> amber -> red as level rises
        let color;
        if (i < meterBars.length - 3) color = '#2a8c4a';
        else if (i < meterBars.length - 1) color = '#d4a373';
        else color = 'var(--pill-rec)';
        b.style.background = color;
      } else {
        b.style.background = '';  // back to var(--rule-strong)
      }
    });
  }

  // ---- TOC ----------------------------------------------------------------

  function renderToc(state) {
    const markers = state.markers || [];
    const tocEl = $('toc');
    if (!markers.length) { tocEl.hidden = true; return; }
    tocEl.hidden = false;
    $('toc-count').textContent = `(${markers.length})`;
    const list = $('toc-list');
    list.innerHTML = '';
    for (const m of markers) {
      const ts = document.createElement('span');
      ts.className = 'ts';
      ts.textContent = fmt(m.t);
      const link = document.createElement('a');
      link.href = `#marker-${m.t.toFixed(1).replace('.', '_')}`;
      link.textContent = m.label.replace(/^\[[\d:]+\]\s*/, '').trim() || '—';
      if (m.user) link.classList.add('user-mark');
      link.addEventListener('click', e => {
        e.preventDefault();
        const target = document.getElementById(link.getAttribute('href').slice(1));
        if (target) {
          target.scrollIntoView({ block: 'start', behavior: 'smooth' });
          following = false;
        }
      });
      list.appendChild(ts);
      list.appendChild(link);
    }
  }

  // ---- main render ---------------------------------------------------------

  function render(state) {
    lastState = state;
    firstStateReceived = true;
    const meta = state.meta || {};
    $('name').textContent = meta.name || 'meeting';
    $('started').textContent = meta.started || '—';
    $('device').textContent = meta.input || '—';
    $('duration').textContent = fmt(state.audio_seconds || 0);
    $('wall-duration').textContent = fmt(state.wall_seconds || 0);

    const pill = $('status');
    pill.classList.remove('starting', 'recording', 'stopped');
    pill.classList.add(state.status);
    $('status-text').textContent = state.status;

    updateMeter(typeof state.peak_db === 'number' ? state.peak_db : -120);

    if (state.warning) {
      $('warning').textContent = state.warning;
      $('warning').hidden = false;
    } else {
      $('warning').hidden = true;
    }

    if (!pathsRendered && meta.paths) {
      const paths = $('paths');
      const labels = { md: 'md', txt: 'txt', flac: 'audio', log: 'log' };
      paths.innerHTML = '';
      for (const k of ['md', 'txt', 'flac', 'log']) {
        if (!meta.paths[k]) continue;
        const lbl = document.createElement('span');
        lbl.className = 'label';
        lbl.textContent = labels[k];
        const val = document.createElement('span');
        val.className = 'val';
        val.textContent = meta.paths[k];
        paths.appendChild(lbl);
        paths.appendChild(val);
      }
      pathsRendered = true;
    }

    if (state.status === 'stopped') {
      stopBtn.disabled = true;
      stopBtn.textContent = 'stopped';
    }

    // Polish status: only show row + raw-toggle when polish is actually active.
    const ps = state.polish_status;
    const pmeta = $('meta-polish');
    const rawBtn = $('btn-toggle-raw');
    const polishOn = ps && ps !== 'disabled';
    if (polishOn) {
      pmeta.hidden = false;
      rawBtn.hidden = false;
      const psv = $('polish-state');
      const labels = {
        'idle': '✓ ' + (state.polish_model || 'on'),
        'running': '… polishing',
        'unreachable': '⚠ ollama offline',
      };
      psv.textContent = labels[ps] || ps;
      psv.style.color = ps === 'unreachable' ? 'var(--pill-rec)' : 'var(--fg-mute)';
    } else {
      pmeta.hidden = true;
      rawBtn.hidden = true;
    }

    renderToc(state);

    const segViews = viewSegments(state);
    const markers = state.markers || [];
    if (segViews.length === 0 && !state.draft) {
      transcript.innerHTML =
        '<div class="empty">' +
        (state.status === 'starting' ? 'Loading model…' : 'Listening…') +
        '</div>';
      return;
    }

    let html = '';
    let buf = [];
    let mi = 0;
    const flushPara = () => {
      if (!buf.length) return;
      const paraText = buf.map(b => b.text.trim()).join(' ');
      const paraRaw = buf.map(b => b.raw.trim()).join(' ');
      const isPolished = !showRaw && paraText !== paraRaw;
      // role="article" gives ARIA-feed pattern; tabindex=-1 lets each
      // paragraph be programmatically focusable for jump-to-time without
      // appearing in tab order.
      if (isPolished) {
        html += `<details class="para" role="article" tabindex="-1">`
              + `<summary>${esc(paraText)}</summary>`
              + `<div class="raw-inline">raw: ${esc(paraRaw)}</div></details>`;
      } else {
        html += `<p role="article" tabindex="-1">${esc(paraText)}</p>`;
      }
      buf = [];
    };
    for (const sv of segViews) {
      while (mi < markers.length && markers[mi].t <= sv.t) {
        flushPara();
        const m = markers[mi];
        const cls = m.user ? 'marker user-mark' : 'marker';
        const id = 'marker-' + m.t.toFixed(1).replace('.', '_');
        html += `<div class="${cls}" id="${id}"><span class="label-text">${esc(m.label)}</span></div>`;
        mi++;
      }
      buf.push(sv);
    }
    flushPara();
    while (mi < markers.length) {
      const m = markers[mi];
      const cls = m.user ? 'marker user-mark' : 'marker';
      const id = 'marker-' + m.t.toFixed(1).replace('.', '_');
      html += `<div class="${cls}" id="${id}"><span class="label-text">${esc(m.label)}</span></div>`;
      mi++;
    }
    if (state.draft && state.status !== 'stopped') {
      html += `<p class="draft">${esc(state.draft.trim())}</p>`;
    }
    transcript.innerHTML = html;
    if (following) window.scrollTo(0, document.body.scrollHeight);

    // Re-apply find if active so highlights survive re-render
    if (findActive && findInput.value.length >= 2) {
      runFind(findInput.value);
    }

    updateJumpBadge();
    updateSpeechRate(state);
  }

  // Speech-rate tracking: count words in the last 30s of segments.
  // > 160 wpm = above DCMP-recommended cap; show warn pill.
  const rateWindow = []; // {t_audio, words}
  function updateSpeechRate(state) {
    const segs = state.segments || [];
    if (!segs.length) return;
    // Most-recent segment
    const latest = segs[segs.length - 1];
    if (rateWindow.length === 0 ||
        rateWindow[rateWindow.length - 1].t < latest.t) {
      const wc = (latest.text || '').trim().split(/\s+/).filter(Boolean).length;
      rateWindow.push({ t: latest.t, words: wc });
    }
    // Drop entries older than 30s of audio
    const cutoff = (state.audio_seconds || 0) - 30;
    while (rateWindow.length && rateWindow[0].t < cutoff) rateWindow.shift();
    if (rateWindow.length < 3) return; // need a few samples
    const totalWords = rateWindow.reduce((a, b) => a + b.words, 0);
    const span = Math.max(1, rateWindow[rateWindow.length - 1].t - rateWindow[0].t);
    const wpm = (totalWords / span) * 60;
    $('rate-warn').classList.toggle('visible', wpm > 160 && state.status === 'recording');
  }

  function esc(s) {
    return s.replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c]);
  }
  function fmt(secs) {
    const s = Math.floor(secs);
    return [s/3600|0, (s%3600)/60|0, s%60]
      .map(n => String(n).padStart(2, '0')).join(':');
  }

  // ---- SSE + connection state ---------------------------------------------

  function setConnState(state) {
    conn.classList.toggle('disconnected', state !== 'live');
    $('conn-text').textContent = state;
  }

  let evt;
  let reconnectTimer = null;
  function connect() {
    if (evt) try { evt.close(); } catch (_) {}
    evt = new EventSource('/events');
    evt.addEventListener('open', () => {
      setConnState('live');
      if (reconnectTimer) { clearTimeout(reconnectTimer); reconnectTimer = null; }
    });
    evt.addEventListener('state', e => {
      try { render(JSON.parse(e.data)); } catch (err) { console.error(err); }
    });
    evt.onerror = () => {
      setConnState('reconnecting');
      // EventSource auto-reconnects, but if the server is fully gone the
      // browser keeps trying every 3s. Surface the disconnected state.
    };
  }
  connect();

  // Periodic liveness check: if no state arrived in 30s, the server may have
  // exited (recording stopped via terminal Ctrl-C); show offline.
  setInterval(() => {
    if (!firstStateReceived) return;
    if (lastState && lastState.status === 'stopped') {
      setConnState('stopped');
      return;
    }
  }, 5000);
})();
</script>
</body>
</html>
"""


def make_handler(state: TranscriptState):
    class Handler(http.server.BaseHTTPRequestHandler):
        def log_message(self, *_):
            pass  # quiet

        def do_GET(self):  # noqa: N802
            if self.path == "/" or self.path == "/index.html":
                body = INDEX_HTML.encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.send_header("Cache-Control", "no-store")
                self.end_headers()
                self.wfile.write(body)
                return
            if self.path == "/events":
                self.send_response(200)
                self.send_header("Content-Type", "text/event-stream")
                self.send_header("Cache-Control", "no-store")
                self.send_header("Connection", "keep-alive")
                self.send_header("X-Accel-Buffering", "no")
                self.end_headers()
                q = state.subscribe()
                try:
                    self._stream(q)
                finally:
                    state.unsubscribe(q)
                return
            if self.path == "/snapshot.json":
                body = json.dumps(state.snapshot()).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return
            self.send_error(404)

        def do_POST(self):  # noqa: N802
            if self.path == "/control/stop":
                state.request_stop()
                self._json_ok({"stopping": True})
                return
            if self.path == "/control/mark":
                state.request_mark()
                self._json_ok({"marked": True})
                return
            self.send_error(404)

        def _json_ok(self, payload: dict) -> None:
            body = json.dumps(payload).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(body)

        def _stream(self, q: queue.Queue):
            # SSE retry hint = 3s
            try:
                self.wfile.write(b"retry: 3000\n\n")
                self.wfile.flush()
                while True:
                    try:
                        snap = q.get(timeout=15)
                    except queue.Empty:
                        # heartbeat to keep proxies + browsers happy
                        self.wfile.write(b": ping\n\n")
                        self.wfile.flush()
                        continue
                    payload = json.dumps(snap, ensure_ascii=False)
                    self.wfile.write(b"event: state\n")
                    self.wfile.write(b"data: " + payload.encode("utf-8") + b"\n\n")
                    self.wfile.flush()
            except (BrokenPipeError, ConnectionResetError, OSError):
                return

    return Handler


class ReusableThreadingServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True

    def handle_error(self, request, client_address):
        # Browsers / curl closing SSE streams produces ConnectionReset/BrokenPipe;
        # those are routine, not real errors. Stay quiet.
        import sys as _sys
        exc = _sys.exc_info()[1]
        if isinstance(exc, (BrokenPipeError, ConnectionResetError)):
            return
        super().handle_error(request, client_address)


def start_server(state: TranscriptState, port: int) -> tuple[ReusableThreadingServer, int, threading.Thread]:
    handler = make_handler(state)
    srv = ReusableThreadingServer(("127.0.0.1", port), handler)
    actual = srv.server_address[1]
    thread = threading.Thread(target=srv.serve_forever, daemon=True)
    thread.start()
    return srv, actual, thread


# ---------- markdown writer ----------

def md_header(meta: dict) -> str:
    lines = [
        "---",
        f"name: {meta['name']}",
        f"started: {meta['started']}",
        f"model: {meta['model']}",
        f"input: {meta['input']}",
        f"audio_file: {meta['audio_file']}",
        f"sample_rate: {SAMPLE_RATE}",
        "---",
        "",
        f"# {meta['name']}",
        "",
        f"_Started {meta['started']}. Live transcript below; this file is",
        f"rewritten on every chunk. Reference it from Claude Code with",
        f"`@{meta['md_path']}` to chat about it mid-meeting._",
        "",
        "## Transcript",
        "",
    ]
    return "\n".join(lines)


def md_footer(audio_s: float, wall_s: float, ended: str) -> str:
    return (
        "\n\n---\n"
        f"_Ended {ended} · {hms(wall_s)} wall · {hms(audio_s)} audio_\n"
    )


def _segments_view(snap: dict) -> list[dict]:
    """Build the polished-when-available segment view (parallel to JS viewSegments)."""
    segs = snap["segments"]
    polished = snap.get("polished_segments") or []
    out: list[dict] = []
    i = 0
    pi = 0
    while i < len(segs):
        p = polished[pi] if pi < len(polished) else None
        if p and p["raw_start_index"] <= i < p["raw_end_index"]:
            out.append({"t": segs[p["raw_start_index"]]["t"], "text": p["text"]})
            i = p["raw_end_index"]
            pi += 1
        else:
            out.append({"t": segs[i]["t"], "text": segs[i]["text"]})
            i += 1
    return out


def render_md(state: TranscriptState, ended: str | None = None) -> str:
    snap = state.snapshot()
    meta = snap["meta"]
    out = [md_header(meta)]
    # Walk segments in append order (which IS chronological by first-token
    # start time). Interleave markers at the right boundary by tracking a
    # marker cursor — do NOT sort the segment list, which would scramble
    # any segments whose t is non-strict-monotonic.
    seg_views = _segments_view(snap)
    markers = snap["markers"]
    paragraph: list[str] = []
    mi = 0
    for sv in seg_views:
        while mi < len(markers) and markers[mi]["t"] <= sv["t"]:
            if paragraph:
                out.append(" ".join(paragraph).strip())
                out.append("")
                paragraph = []
            out.append(f"### {markers[mi]['label']}")
            out.append("")
            mi += 1
        paragraph.append(sv["text"].strip())
    if paragraph:
        out.append(" ".join(paragraph).strip())
        out.append("")
    while mi < len(markers):
        out.append(f"### {markers[mi]['label']}")
        out.append("")
        mi += 1
    if snap["draft"] and snap["status"] != "stopped":
        out.append("")
        out.append(f"_…{snap['draft'].strip()}_")
    if ended is not None:
        out.append(md_footer(snap["audio_seconds"], snap["wall_seconds"], ended))
    return "\n".join(out) + "\n"


def run_offline_pass(
    flac_path: Path, model, mx, name: str, started_str: str,
    model_name: str, dev_label: str, log_fn=None,
) -> tuple[Path, Path] | None:
    """Re-transcribe the saved FLAC offline (full-attention, chunked) and
    write <name>.offline.{md,txt}. Returns paths or None on failure.

    Empirical: offline transcription on the same FLAC dramatically improves
    accuracy ("non-Jeb ins" -> "non Jeff admins", "Cross Camp" -> "Chris Kemp",
    "Lake Quake" -> "escalate quick"). The streaming local-attention window
    is the cause of those misses; offline gets the full encoder context.
    """
    out_dir = flac_path.parent
    md_path = out_dir / f"{name}.offline.md"
    txt_path = out_dir / f"{name}.offline.txt"
    json_path = out_dir / f"{name}.offline.json"

    log = log_fn or (lambda s: print(s, file=sys.stderr, flush=True))
    log(f"offline pass on {flac_path.name} ...")
    t0 = time.time()
    try:
        # chunk_duration=120 was silently dropping the last 40% of audio
        # on clips whose duration was a near-multiple of the chunk size
        # (eval 2026-05-07: 120s clip → 71.9s of transcript). Smaller
        # chunks at higher overlap eliminate the boundary edge case;
        # offline pass is fast enough (~20s/hr) that the 4× chunk count
        # is not a runtime concern.
        result = model.transcribe(
            str(flac_path),
            chunk_duration=30.0,
            overlap_duration=5.0,
        )
    except Exception as e:
        log(f"offline pass FAILED: {e}")
        return None

    sentences = result.sentences or []
    if not sentences:
        log("offline pass produced no sentences")
        return None

    elapsed = time.time() - t0

    # Non-speech metadata: paragraph break on >2s silence, inline marker on >5s.
    # These are timestamp-derived (no extra ML); compose with diarization since
    # sherpa attaches speaker labels by overlap with these same sentence spans.
    PARA_GAP = 2.0    # >this seconds = paragraph break
    PAUSE_INLINE = 5.0  # >this seconds = explicit [pause: Ns] marker
    paras: list[list[str]] = [[]]
    last_end = 0.0
    for s in sentences:
        gap = s.start - last_end if last_end > 0 else 0.0
        if gap > PAUSE_INLINE and paras[-1]:
            # large silence: paragraph break PLUS inline marker
            paras[-1].append(f"\n\n_[pause: {gap:.1f}s]_")
            paras.append([])
        elif gap > PARA_GAP and paras[-1]:
            paras.append([])
        paras[-1].append(s.text.strip())
        last_end = s.end
    txt_body = "\n\n".join(" ".join(p).replace("\n\n_", "\n\n_") for p in paras if p)
    txt_path.write_text(
        f"# meeting-record (offline re-pass)\n"
        f"# name:    {name}\n"
        f"# started: {started_str}\n"
        f"# model:   {model_name}\n"
        f"# input:   {dev_label}\n"
        f"# source:  {flac_path.name}\n\n"
        f"{txt_body}\n",
        encoding="utf-8",
    )

    # md: with frontmatter, ## Transcript, paragraph breaks on silence
    md_body = txt_body
    md_path.write_text(
        f"---\n"
        f"name: {name}\n"
        f"started: {started_str}\n"
        f"model: {model_name}\n"
        f"input: {dev_label}\n"
        f"audio_file: {flac_path.name}\n"
        f"sample_rate: {SAMPLE_RATE}\n"
        f"pass: offline\n"
        f"---\n\n"
        f"# {name} (offline)\n\n"
        f"_Re-transcribed offline from {flac_path.name} after the meeting._\n"
        f"_This pass uses full-attention chunks of 2min and is more accurate "
        f"than the streaming live transcript._\n\n"
        f"## Transcript\n\n"
        f"{md_body}\n",
        encoding="utf-8",
    )

    # json: per-sentence with timestamps (feeds search, summary, future LLM-polish)
    json_path.write_text(
        json.dumps({
            "name": name,
            "model": model_name,
            "audio_file": flac_path.name,
            "sentences": [
                {"text": s.text, "start": s.start, "end": s.end,
                 "duration": s.duration}
                for s in sentences
            ],
        }, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )

    log(f"offline pass: {elapsed:.0f}s wall, "
        f"{len(sentences)} sentences -> {md_path.name}")
    return md_path, json_path


# ---------- diarization ----------

DIARIZE_MODEL_DIR = Path.home() / ".cache" / "meeting-record" / "diarize"
DIARIZE_SEG_URL = (
    "https://github.com/k2-fsa/sherpa-onnx/releases/download/"
    "speaker-segmentation-models/sherpa-onnx-pyannote-segmentation-3-0.tar.bz2"
)
DIARIZE_EMB_URL = (
    "https://github.com/k2-fsa/sherpa-onnx/releases/download/"
    "speaker-recongition-models/3dspeaker_speech_campplus_sv_en_voxceleb_16k.onnx"
)


def _download(url: str, dest: Path, log_fn) -> None:
    """Download with progress logging. Atomic via .tmp + rename."""
    import urllib.request
    dest.parent.mkdir(parents=True, exist_ok=True)
    tmp = dest.with_suffix(dest.suffix + ".tmp")
    log_fn(f"  downloading {dest.name} ...")
    urllib.request.urlretrieve(url, str(tmp))
    tmp.rename(dest)


def _ensure_diarize_models(log_fn) -> tuple[Path, Path]:
    """Download segmentation + embedding models on first use; cache at
    ~/.cache/meeting-record/diarize/. Returns (segmentation_path, embedding_path)."""
    DIARIZE_MODEL_DIR.mkdir(parents=True, exist_ok=True)
    seg_dir = DIARIZE_MODEL_DIR / "sherpa-onnx-pyannote-segmentation-3-0"
    seg_path = seg_dir / "model.onnx"
    emb_path = DIARIZE_MODEL_DIR / "campplus_voxceleb_16k.onnx"

    if not seg_path.exists():
        tarball = DIARIZE_MODEL_DIR / "segmentation.tar.bz2"
        if not tarball.exists():
            _download(DIARIZE_SEG_URL, tarball, log_fn)
        log_fn(f"  extracting {tarball.name} ...")
        import tarfile
        with tarfile.open(tarball, "r:bz2") as tf:
            # `filter='data'` (Python 3.12+) blocks the tar-bomb / setuid
            # / abs-path attack classes. The 3.14 deprecation warning was
            # nudging us toward this; sherpa-onnx releases are trusted but
            # belt-and-braces is cheap.
            try:
                tf.extractall(DIARIZE_MODEL_DIR, filter="data")
            except TypeError:
                tf.extractall(DIARIZE_MODEL_DIR)  # py < 3.12
        if not seg_path.exists():
            raise RuntimeError(f"expected {seg_path} after extract")

    if not emb_path.exists():
        _download(DIARIZE_EMB_URL, emb_path, log_fn)

    return seg_path, emb_path


def run_diarize_pass(
    flac_path: Path, offline_json_path: Path, name: str,
    num_speakers: int = -1, threshold: float = 0.65, log_fn=None,
) -> Path | None:
    """Run sherpa-onnx pyannote diarization on the FLAC, attach speaker labels
    to offline.json sentences by timestamp overlap, write <name>.diarized.md.

    num_speakers: -1 = auto-detect via clustering threshold, >=2 = pinned.
    """
    log = log_fn or (lambda s: print(s, file=sys.stderr, flush=True))
    if not offline_json_path.exists():
        log(f"diarize: no offline transcript at {offline_json_path}, skipping")
        return None

    log(f"diarize on {flac_path.name} ...")
    t0 = time.time()
    try:
        seg_path, emb_path = _ensure_diarize_models(log)
    except Exception as e:
        log(f"diarize FAILED at model download: {e}")
        return None

    try:
        import sherpa_onnx
        import soundfile as sf
    except ImportError as e:
        log(f"diarize FAILED: {e}")
        return None

    # Load audio. soundfile reads FLAC natively, but if ffmpeg was SIGINT'd
    # mid-write the FLAC trailer may be missing and libsndfile can't compute
    # the array size, raising "array is too big". Fall back to ffmpeg-decode
    # which is more lenient on partial FLACs (it stops at last decodable frame).
    try:
        audio, sr = sf.read(str(flac_path), dtype="float32", always_2d=False)
    except Exception as e:
        log(f"  soundfile failed ({e}); falling back to ffmpeg decode")
        wav_tmp = flac_path.with_suffix(".diarize.tmp.wav")
        try:
            subprocess.run(
                ["ffmpeg", "-hide_banner", "-loglevel", "error",
                 "-i", str(flac_path),
                 "-ac", "1", "-ar", "16000", "-c:a", "pcm_s16le",
                 "-y", str(wav_tmp)],
                check=True,
            )
            audio, sr = sf.read(str(wav_tmp), dtype="float32", always_2d=False)
        finally:
            if wav_tmp.exists():
                wav_tmp.unlink()
    if audio.ndim == 2:
        audio = audio.mean(axis=1)  # downmix
    if sr != 16000:
        log(f"diarize FAILED: expected 16kHz, got {sr}Hz")
        return None

    seg_cfg = sherpa_onnx.OfflineSpeakerSegmentationModelConfig(
        pyannote=sherpa_onnx.OfflineSpeakerSegmentationPyannoteModelConfig(
            model=str(seg_path)
        )
    )
    emb_cfg = sherpa_onnx.SpeakerEmbeddingExtractorConfig(model=str(emb_path))
    clu_cfg = sherpa_onnx.FastClusteringConfig(
        num_clusters=num_speakers,  # -1 = auto via threshold
        # threshold tuned for 3D-Speaker CAMPP on real-world meeting audio.
        # 0.5 over-clusters (25+ speakers in a 5-person meeting). 0.7 in
        # sherpa demos is for clean broadcast TV. 0.65 is a reasonable
        # default for compressed VoIP / room mic conditions.
        threshold=threshold,
    )
    cfg = sherpa_onnx.OfflineSpeakerDiarizationConfig(
        segmentation=seg_cfg,
        embedding=emb_cfg,
        clustering=clu_cfg,
        min_duration_on=0.3,
        min_duration_off=0.5,
    )

    sd = sherpa_onnx.OfflineSpeakerDiarization(cfg)
    result = sd.process(audio)
    speaker_segments = result.sort_by_start_time() if hasattr(result, "sort_by_start_time") else result

    # `speaker_segments` is iterable of OfflineSpeakerDiarizationSegment with
    # .start, .end, .speaker (int).
    spk_spans: list[tuple[float, float, int]] = []
    try:
        for seg in speaker_segments:
            spk_spans.append((float(seg.start), float(seg.end), int(seg.speaker)))
    except TypeError:
        # if not directly iterable, try .segments or call result()
        items = getattr(result, "segments", None) or list(result)
        for seg in items:
            spk_spans.append((float(seg.start), float(seg.end), int(seg.speaker)))

    if not spk_spans:
        log("diarize: no speaker segments produced")
        return None

    # Load the offline transcript JSON: list of sentences with start/end.
    offline = json.loads(offline_json_path.read_text(encoding="utf-8"))
    sentences = offline.get("sentences", [])

    # Attach speaker label to each sentence by max-overlap.
    def best_speaker(s_start: float, s_end: float) -> int | None:
        best, best_overlap = None, 0.0
        for sp_s, sp_e, sp in spk_spans:
            ov = max(0.0, min(sp_e, s_end) - max(sp_s, s_start))
            if ov > best_overlap:
                best_overlap = ov
                best = sp
        return best

    labelled: list[dict] = []
    for s in sentences:
        spk = best_speaker(float(s["start"]), float(s["end"]))
        labelled.append({**s, "speaker": spk})

    # Render <name>.diarized.md: paragraph per consecutive same-speaker run.
    md_path = flac_path.parent / f"{name}.diarized.md"
    json_out_path = flac_path.parent / f"{name}.diarized.json"

    # Group consecutive same-speaker sentences. Insert pause markers on
    # large gaps within a single speaker's turn (turn-internal silence).
    PAUSE_INLINE = 5.0
    paras: list[tuple[int, list[str]]] = []
    cur_spk = None
    last_end = 0.0
    for s in labelled:
        spk = s["speaker"]
        gap = s["start"] - last_end if last_end > 0 else 0.0
        if spk != cur_spk:
            paras.append((spk, []))
            cur_spk = spk
        elif gap > PAUSE_INLINE:
            # same speaker, long silence: annotate inline
            paras[-1][1].append(f"_[pause: {gap:.1f}s]_")
        paras[-1][1].append(s["text"].strip())
        last_end = s["end"]

    n_speakers = len({sp for sp in (s["speaker"] for s in labelled) if sp is not None})
    body = []
    for spk, sents in paras:
        if not sents:
            continue
        label = f"Speaker {spk + 1}" if spk is not None else "Speaker ?"
        body.append(f"**{label}:** {' '.join(sents)}\n")
    body_str = "\n".join(body)

    md_path.write_text(
        f"---\n"
        f"name: {name}\n"
        f"audio_file: {flac_path.name}\n"
        f"speakers_detected: {n_speakers}\n"
        f"diarize_segments: {len(spk_spans)}\n"
        f"pass: diarized\n"
        f"---\n\n"
        f"# {name} (diarized)\n\n"
        f"_Speaker labels are auto-detected; rename them by editing this file._\n"
        f"_Detected {n_speakers} speakers across {len(spk_spans)} segments._\n\n"
        f"## Transcript\n\n"
        f"{body_str}\n",
        encoding="utf-8",
    )
    json_out_path.write_text(
        json.dumps({
            "name": name,
            "speakers_detected": n_speakers,
            "speaker_spans": [
                {"start": s, "end": e, "speaker": sp} for s, e, sp in spk_spans
            ],
            "sentences": labelled,
        }, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    elapsed = time.time() - t0
    log(f"diarize: {elapsed:.0f}s wall, {n_speakers} speakers, "
        f"{len(spk_spans)} segments -> {md_path.name}")
    return md_path


SUMMARY_PROMPT = """\
You are summarizing a meeting transcript. Read it carefully and produce
exactly four sections in this order:

## Summary
A 3-sentence executive summary. Concrete, specific. No filler.

## Decisions
Decisions that were resolved (not just discussed). Bullet points.
If none, write "None recorded."

## Action items
Format: `- **<Name>**: <action>` with a date if mentioned (`(by YYYY-MM-DD)` or `(by Friday)`).
Owner first, action second. If no clear owner, write "Unassigned".
If none, write "None recorded."

## Open questions
Questions left unresolved at the end of the meeting. Bullet points.
If none, write "None recorded."

Strict rules:
- Use only information present in the transcript. Do NOT invent owners,
  dates, or details.
- Names and proper nouns: copy them exactly as the transcript spells them
  (the transcript may have ASR errors but those are the speakers' actual
  names from the meeting).
- Skip filler. Each bullet is one tight sentence.
- Do NOT add a preamble like "Here is the summary:". Start with `## Summary`.
