# ---------- search (SQLite FTS5) ----------

def _search_db_path() -> Path:
    base = Path(os.environ.get(
        "MEETING_DIR", str(Path.home() / "recordings")))
    base.mkdir(parents=True, exist_ok=True)
    return base / ".index.sqlite"


def _search_open() -> "sqlite3.Connection":
    import sqlite3
    db = sqlite3.connect(str(_search_db_path()))
    db.execute("""
        CREATE TABLE IF NOT EXISTS recordings (
            name TEXT PRIMARY KEY,
            started TEXT,
            input TEXT,
            duration_audio_s REAL,
            md_path TEXT,
            offline_path TEXT,
            indexed_at TEXT
        )
    """)
    # FTS5 over per-paragraph rows so we can return tight snippets.
    db.execute("""
        CREATE VIRTUAL TABLE IF NOT EXISTS chunks USING fts5(
            name,
            paragraph,
            t_start,
            tokenize = 'porter unicode61'
        )
    """)
    return db


def _index_one(db, md_path: Path, name: str) -> int:
    """Index a transcript .md into the FTS table. Returns chunk count."""
    raw = md_path.read_text(encoding="utf-8")
    body = strip_meta_lines(raw)
    # F5 fix: drop italic meta lines and the "## Transcript" header that the
    # offline.md wraps the body in. These are tool-generated decorations, not
    # transcript content — they pollute search results with phrases like
    # "Re-transcribed offline from".
    cleaned_lines = []
    for ln in body.splitlines():
        s = ln.strip()
        if not s:
            cleaned_lines.append("")
            continue
        if s.startswith("##"):
            continue  # ## Transcript header
        if s.startswith("_") and s.endswith("_") and len(s) > 2:
            continue  # _italic meta_
        cleaned_lines.append(ln)
    body = "\n".join(cleaned_lines).strip()
    paras = [p.strip() for p in body.split("\n\n") if p.strip()]
    db.execute("DELETE FROM chunks WHERE name = ?", (name,))
    for i, p in enumerate(paras):
        db.execute(
            "INSERT INTO chunks (name, paragraph, t_start) VALUES (?, ?, ?)",
            (name, p, str(i)),
        )
    return len(paras)


def _index_after_offline(md_path: Path, name: str) -> None:
    """Update the FTS index for one recording after offline pass writes its
    .md. Called from main() so users don't have to remember --reindex."""
    db = _search_open()
    try:
        n = _index_one(db, md_path, name)
        db.commit()
        if n:
            print(f"search index: +{n} paragraphs ({name})", file=sys.stderr)
    finally:
        db.close()


def cmd_search(rest: list[str]) -> int:
    p = argparse.ArgumentParser(prog="recorder search")
    p.add_argument("query", nargs="?", help="full-text query (FTS5 syntax)")
    p.add_argument("--reindex", action="store_true",
                   help="rebuild the index from ~/recordings/*.offline.md (or .md fallback)")
    p.add_argument("--limit", type=int, default=10)
    p.add_argument("--snippet", type=int, default=160,
                   help="snippet length in chars (default 160)")
    args = p.parse_args(rest)

    out_dir = Path(os.environ.get(
        "MEETING_DIR", str(Path.home() / "recordings")))

    db = _search_open()

    if args.reindex:
        n = 0
        # Prefer offline transcript when it exists; fallback to live .md.
        offline_files = sorted(out_dir.glob("*.offline.md"))
        offline_names = {f.name.replace(".offline.md", "") for f in offline_files}
        live_files = [
            f for f in sorted(out_dir.glob("*.md"))
            if not f.name.endswith(".offline.md")
            and not f.name.endswith(".summary.md")
            and not f.name.endswith(".polished.md")
            and f.stem not in offline_names
        ]
        for f in offline_files:
            name = f.name[: -len(".offline.md")]
            n += _index_one(db, f, name)
        for f in live_files:
            n += _index_one(db, f, f.stem)
        db.commit()
        meta_count = db.execute("SELECT COUNT(*) FROM chunks").fetchone()[0]
        print(f"indexed {meta_count} paragraphs across "
              f"{len(offline_files) + len(live_files)} recordings",
              file=sys.stderr)

    if not args.query:
        return 0

    # F6 fix: FTS5 has its own query syntax (operators ., :, *, ?, AND, OR, NOT,
    # quoted phrases). User-supplied free text with apostrophes/punctuation
    # crashes with sqlite3.OperationalError. Strategy: try the literal query
    # (lets power users use FTS5 ops), on syntax error wrap as a quoted phrase.
    import sqlite3
    sql = (
        f"SELECT name, snippet(chunks, 1, '\x1b[1;33m', '\x1b[0m', '…', "
        f"{max(8, args.snippet // 6)}) "
        f"FROM chunks WHERE paragraph MATCH ? "
        f"ORDER BY rank LIMIT ?"
    )
    try:
        cur = db.execute(sql, (args.query, args.limit))
        rows = cur.fetchall()
    except sqlite3.OperationalError:
        # Fall back to a phrase-quoted query: escape any " in the input and wrap.
        safe = '"' + args.query.replace('"', '""') + '"'
        try:
            cur = db.execute(sql, (safe, args.limit))
            rows = cur.fetchall()
        except sqlite3.OperationalError as e:
            print(f"search query syntax error: {e}\n"
                  f"  try simpler keywords, e.g. `recorder search budget`",
                  file=sys.stderr)
            return 1
    if not rows:
        print(f"no results for {args.query!r} (try `--reindex` or different query)",
              file=sys.stderr)
        return 1
    for name, snippet in rows:
        print(f"\n\x1b[1;36m{name}\x1b[0m")
        print(f"  {snippet}")
    print("", file=sys.stderr)
    return 0


