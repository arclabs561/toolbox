# ---------- audio device helpers ----------

def avfoundation_devices() -> list[tuple[str, str]]:
    """Return [(index, name)] for AVFoundation audio inputs."""
    proc = subprocess.run(
        ["ffmpeg", "-hide_banner", "-f", "avfoundation",
         "-list_devices", "true", "-i", ""],
        capture_output=True, text=True,
    )
    out: list[tuple[str, str]] = []
    in_audio = False
    for line in proc.stderr.splitlines():
        if "AVFoundation audio devices" in line:
            in_audio = True
            continue
        if in_audio:
            m = re.search(r"\[(\d+)\]\s+(.+)$", line)
            if m:
                out.append((m.group(1), m.group(2).strip()))
            elif "AVFoundation" in line:
                break
    return out


def device_label(device: str) -> str:
    m = re.fullmatch(r":(\d+)", device)
    if not m:
        return device
    idx = m.group(1)
    for i, name in avfoundation_devices():
        if i == idx:
            return f"{device} ({name})"
    return device


def auto_detect_device(user_device: str, env_set: bool) -> str:
    """Opportunistically prefer a BlackHole-containing aggregate device
    when the user hasn't pinned one explicitly.

    Returns the device string to actually use. Logs to stderr when the
    auto-detected device differs from the default. Stays silent when no
    aggregate is present (the default :0 works fine for mic-only).

    Triggers ONLY when:
      - user did not pass --device on the CLI (default ":0")
      - MEETING_DEVICE env var is unset
      - an avfoundation aggregate device whose name contains "blackhole"
        OR whose name suggests it's an aggregate is present
    """
    if user_device != ":0" or env_set:
        return user_device
    try:
        devs = avfoundation_devices()
    except Exception:
        return user_device
    bh_agg = [(i, n) for i, n in devs
              if "blackhole" in n.lower() and ("aggregate" in n.lower()
                                                or "+" in n
                                                or "recorder" in n.lower())]
    plain_agg = [(i, n) for i, n in devs
                 if "aggregate" in n.lower() and i != "0"]
    pick = (bh_agg or plain_agg)[:1]
    if not pick:
        return user_device
    i, n = pick[0]
    sys.stderr.write(
        f"[auto-detect] using aggregate device :{i} ({n}). "
        f"pass --device ':0' to force mic-only.\n"
    )
    return f":{i}"


def list_devices() -> int:
    proc = subprocess.run(
        ["ffmpeg", "-hide_banner", "-f", "avfoundation",
         "-list_devices", "true", "-i", ""],
        capture_output=True, text=True,
    )
    sys.stderr.write(proc.stderr)

    # System-audio capture hint: detect BlackHole or an Aggregate Device and
    # surface the pattern. Until the ScreenCaptureKit Swift shim ships,
    # BlackHole is the documented path to capture remote-meeting audio
    # (Zoom/Meet) alongside the local mic.
    devs = avfoundation_devices()
    bh = [(i, n) for i, n in devs if "blackhole" in n.lower()]
    agg = [(i, n) for i, n in devs if "aggregate" in n.lower() or "multi-output" in n.lower()]
    if bh or agg:
        sys.stderr.write("\n[system-audio capture]\n")
        if agg:
            i, n = agg[0]
            sys.stderr.write(
                f"  detected aggregate device: [{i}] {n}\n"
                f"  to capture mic + system audio together:\n"
                f"      recorder --device ':{i}' <name>\n"
            )
        elif bh:
            i, n = bh[0]
            sys.stderr.write(
                f"  detected BlackHole at [{i}] {n}, but no aggregate device.\n"
                f"  to capture mic + system audio together:\n"
                f"  1. open Audio MIDI Setup\n"
                f"  2. create an Aggregate Device combining BlackHole + your mic\n"
                f"  3. set a Multi-Output Device (BlackHole + speakers) as system output\n"
                f"  4. then: recorder --device ':<aggregate-index>' <name>\n"
            )
    else:
        sys.stderr.write(
            "\n[system-audio capture]\n"
            "  to capture remote-meeting audio (Zoom/Meet) alongside the mic:\n"
            "      brew install --cask blackhole-2ch\n"
            "  then create an Aggregate Device in Audio MIDI Setup.\n"
        )
    return 0


def build_ffmpeg_cmd(device: str, from_file: str | None, flac_path: Path) -> list[str]:
    if from_file:
        input_args = ["-i", from_file]
    else:
        input_args = ["-f", "avfoundation", "-i", device]
    return [
        "ffmpeg", "-hide_banner", "-loglevel", "warning",
        *input_args,
        "-ac", "1", "-ar", str(SAMPLE_RATE),
        "-c:a", "flac", "-flush_packets", "1",
        "-y", str(flac_path),
        "-ac", "1", "-ar", str(SAMPLE_RATE),
        "-f", "f32le", "-c:a", "pcm_f32le",
        "pipe:1",
    ]


def read_exact(fp, n: int) -> bytes:
    out = bytearray()
    while len(out) < n:
        chunk = fp.read(n - len(out))
        if not chunk:
            break
        out.extend(chunk)
    return bytes(out)


def hms(secs: float) -> str:
    s = int(secs)
    return f"{s // 3600:02d}:{(s % 3600) // 60:02d}:{s % 60:02d}"


# ---------- transcript state (shared between writer + HTTP server) ----------

class TranscriptState:
    """Thread-safe live transcript view.

    `segments` is the durable, finalized history (list of dicts with text +
    audio_start). `draft` is the most recent unfinalized prediction. `meta`
    holds frontmatter-style fields the page renders in the header.
    """

    def __init__(self, meta: dict):
        self._lock = threading.Lock()
        self.meta = meta
        # `segments` holds raw parakeet output (one entry per finalized batch).
        # `polished_segments` holds the cleaned version aligned by raw-text
        # match: each polished entry replaces the consecutive run of raw
        # segments whose concatenation it covers. Until polish has run for a
        # raw segment, the polished view falls back to the raw text.
        self.segments: list[dict] = []   # [{"t": float, "text": str}]
        self.polished_segments: list[dict] = []  # [{"t": float, "text": str, "raw": str}]
        self.polish_status: str = "idle"  # idle | running | unreachable | disabled
        self.polish_model: str | None = None
        self.markers: list[dict] = []    # [{"t": float, "label": str}]
        self.draft: str = ""
        self.audio_seconds: float = 0.0
        self.wall_seconds: float = 0.0
        # Audio level: smoothed peak in dBFS over the last few chunks.
        # -inf = silent, 0 = clipping. Renders the live mic meter.
        self.peak_db: float = -120.0
        self.status: str = "starting"    # starting | recording | stopped
        self.warning: str | None = None
        self.subscribers: list[queue.Queue] = []
        # Operator controls: set by the HTTP handler, read by the main loop.
        self.stop_requested: bool = False
        self.mark_requested: bool = False

    # mutators ---------------------------------------------------------------

    def append_finalized(self, text: str, t: float) -> None:
        with self._lock:
            self.segments.append({"t": t, "text": text})
            self._notify()

    def replace_polished_window(
        self, start_index: int, end_index: int,
        polished: str, raw: str,
    ) -> None:
        """Insert/replace a polished block covering segments[start_index:end_index].

        Both indices are taken from the snapshot at polish-pass time, NOT the
        current live state -- segments may have grown during the LLM call, and
        attributing late-arrived segments to the polish would silently consume
        them on render (the F1/F2 bug class from the flaws review).

        Filter: keep any existing polished entries that don't overlap with
        [start_index, end_index). Entries fully before stay; entries fully
        after stay; partial overlaps are dropped (rare, and easier to redo
        than to merge).
        """
        with self._lock:
            if start_index >= end_index or end_index > len(self.segments):
                # snapshot is older than live state's segment list shrunk
                # (shouldn't happen) or window is empty; bail.
                return
            self.polished_segments = [
                p for p in self.polished_segments
                if p["raw_end_index"] <= start_index or p["raw_start_index"] >= end_index
            ]
            t = self.segments[start_index]["t"]
            self.polished_segments.append({
                "t": t,
                "text": polished.strip(),
                "raw": raw.strip(),
                "raw_start_index": start_index,
                "raw_end_index": end_index,
            })
            # Keep order so JS can iterate in segment order without sorting.
            self.polished_segments.sort(key=lambda p: p["raw_start_index"])
            self._notify()

    def set_polish_status(self, status: str, model: str | None = None) -> None:
        with self._lock:
            self.polish_status = status
            if model is not None:
                self.polish_model = model
            self._notify()

    def add_marker(self, t: float, label: str, user: bool = False) -> None:
        with self._lock:
            self.markers.append({"t": t, "label": label, "user": user})
            self._notify()

    def request_stop(self) -> None:
        with self._lock:
            self.stop_requested = True
            self._notify()

    def request_mark(self) -> None:
        with self._lock:
            self.mark_requested = True

    def set_draft(self, text: str, audio_s: float, wall_s: float,
                  peak_db: float | None = None) -> None:
        with self._lock:
            self.draft = text
            self.audio_seconds = audio_s
            self.wall_seconds = wall_s
            if peak_db is not None:
                # Exponential decay smoothing so the meter reads as a
                # short-term envelope rather than per-chunk jitter.
                # Faster attack than release: ringy peaks register but die
                # gracefully so silence reads as silence.
                if peak_db > self.peak_db:
                    self.peak_db = peak_db
                else:
                    self.peak_db = self.peak_db * 0.6 + peak_db * 0.4
            self._notify()

    def set_status(self, status: str, warning: str | None = None) -> None:
        with self._lock:
            self.status = status
            if warning is not None:
                self.warning = warning
            self._notify()

    # subscribers ------------------------------------------------------------

    def subscribe(self) -> queue.Queue:
        q: queue.Queue = queue.Queue(maxsize=64)
        with self._lock:
            self.subscribers.append(q)
            q.put_nowait(self._snapshot_locked())
        return q

    def unsubscribe(self, q: queue.Queue) -> None:
        with self._lock:
            try:
                self.subscribers.remove(q)
            except ValueError:
                pass

    def _notify(self) -> None:
        snap = self._snapshot_locked()
        dead = []
        for q in self.subscribers:
            try:
                q.put_nowait(snap)
            except queue.Full:
                # slow client: drop the queue, client will reconnect via SSE retry
                dead.append(q)
        for q in dead:
            try:
                self.subscribers.remove(q)
            except ValueError:
                pass

    def _snapshot_locked(self) -> dict:
        return {
            "meta": self.meta,
            "segments": list(self.segments),
            "polished_segments": list(self.polished_segments),
            "polish_status": self.polish_status,
            "polish_model": self.polish_model,
            "markers": list(self.markers),
            "draft": self.draft,
            "audio_seconds": self.audio_seconds,
            "wall_seconds": self.wall_seconds,
            "peak_db": self.peak_db,
            "status": self.status,
            "warning": self.warning,
        }

    def snapshot(self) -> dict:
        with self._lock:
            return self._snapshot_locked()


