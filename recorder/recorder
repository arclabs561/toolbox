def cmd_redo(rest: list[str]) -> int:
    p = argparse.ArgumentParser(prog="recorder redo")
    p.add_argument("flac", help="path to a saved FLAC")
    p.add_argument("--model", default=os.environ.get(
        "PARAKEET_MODEL", "mlx-community/parakeet-tdt-0.6b-v3"))
    p.add_argument("--force", action="store_true",
                   help="overwrite existing <name>.offline.md if present")
    args = p.parse_args(rest)

    flac_path = Path(args.flac).expanduser().resolve()
    if not flac_path.exists():
        print(f"flac not found: {flac_path}", file=sys.stderr)
        return 1

    name = flac_path.stem
    existing_md = flac_path.parent / f"{name}.offline.md"
    if existing_md.exists() and not args.force:
        print(
            f"refusing to overwrite {existing_md}\n"
            f"  (it may contain hand-edits). re-run with --force to overwrite.",
            file=sys.stderr,
        )
        return 1
    # F2 (cumulative-flaws): on --force, also remove stale diarized.md whose
    # speaker spans came from the prior offline.json. Otherwise the user ends
    # up with offline.md (new) + diarized.md (stale, mismatched timestamps).
    if args.force:
        for ext in (".diarized.md", ".diarized.json", ".summary.md"):
            stale = flac_path.parent / f"{name}{ext}"
            if stale.exists():
                print(f"  removing stale {stale.name} (will need to be regenerated)",
                      file=sys.stderr)
                stale.unlink()
    print(f"loading {args.model} ...", file=sys.stderr, flush=True)
    import mlx.core as mx
    from parakeet_mlx import from_pretrained
    model = from_pretrained(args.model)

    started_str = datetime.fromtimestamp(
        flac_path.stat().st_mtime).strftime("%Y-%m-%d %H:%M:%S %Z")
    paths = run_offline_pass(
        flac_path, model, mx, name, started_str, args.model, "from existing FLAC",
    )
    # F2 (cumulative-flaws): keep search index in sync after redo too.
    if paths is not None:
        try:
            _index_after_offline(paths[0], name)
        except Exception as e:
            print(f"search index update skipped: {e}", file=sys.stderr)
    return 0 if paths else 1


