SUMMARY_REDUCE_PROMPT = """\
You are merging multiple partial meeting summaries (each from a 30-min
chunk of the same meeting) into one coherent summary.

Combine them into the SAME four sections. Deduplicate. Keep the most
specific action items (preferring ones with named owners and dates).
Drop any item that contradicts a later chunk's resolution.

Do NOT invent new content. Output the four sections only, no preamble.
"""


def run_summary_pass(
    offline_md: Path, model: str, name: str, dev_label: str, started_str: str,
) -> Path:
    """Generate a structured summary from the offline transcript via Ollama.

    For long transcripts (>~24k chars, roughly the safe ceiling under a
    32k-token context window with system prompt + output budget), summarize
    each ~6k-char chunk separately then reduce. Without this, Ollama
    silently truncates input from the END — losing exactly the action items
    and decisions that land at the end of a meeting.
    """
    raw = offline_md.read_text(encoding="utf-8")
    body = strip_meta_lines(raw)
    if len(body) < 100:
        raise RuntimeError(f"transcript too short ({len(body)} chars) to summarize")

    LONG_THRESHOLD = 24000  # chars; below this a single pass is fine
    chunks = chunk_text(body, max_chars=6000, overlap=200) if len(body) > LONG_THRESHOLD else [body]

    sys.stderr.write(
        f"summary pass with {model} on {len(body)} chars"
        + (f" ({len(chunks)} chunks, map-reduce)" if len(chunks) > 1 else "")
        + " ...\n"
    )
    t0 = time.time()

    if len(chunks) == 1:
        out = ollama_chat(
            model,
            [
                {"role": "system", "content": SUMMARY_PROMPT},
                {"role": "user", "content": body},
            ],
            stream=False, timeout=600, num_predict=2000,
        )
    else:
        # Map: summarize each chunk
        partials = []
        for i, c in enumerate(chunks, 1):
            sys.stderr.write(f"  summary chunk {i}/{len(chunks)} ...\n")
            partials.append(ollama_chat(
                model,
                [
                    {"role": "system", "content": SUMMARY_PROMPT},
                    {"role": "user",
                     "content": f"[meeting chunk {i}/{len(chunks)}]\n\n{c}"},
                ],
                stream=False, timeout=600, num_predict=1500,
            ).strip())
        # Reduce: combine the partial summaries
        merged_input = "\n\n---\n\n".join(
            f"## Partial summary {i}\n\n{p}" for i, p in enumerate(partials, 1)
        )
        sys.stderr.write(f"  reducing {len(partials)} partials ...\n")
        out = ollama_chat(
            model,
            [
                {"role": "system", "content": SUMMARY_REDUCE_PROMPT},
                {"role": "user", "content": merged_input},
            ],
            stream=False, timeout=600, num_predict=2500,
        )
    elapsed = time.time() - t0

    summary_path = offline_md.with_name(f"{name}.summary.md")
    summary_path.write_text(
        f"---\n"
        f"name: {name}\n"
        f"started: {started_str}\n"
        f"input: {dev_label}\n"
        f"summary_model: {model}\n"
        f"source: {offline_md.name}\n"
        f"---\n\n"
        f"# {name} — summary\n\n"
        f"_Auto-generated by {model} from the offline transcript "
        f"({elapsed:.0f}s wall). Spot-check before sharing._\n\n"
        f"{out.strip()}\n",
        encoding="utf-8",
    )
    return summary_path


def write_md_atomic(md_path: Path, content: str) -> None:
    """Atomic rewrite: write to .tmp, fsync, rename. Reader never sees torn state."""
    tmp = md_path.with_suffix(md_path.suffix + ".tmp")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o644)
    try:
        os.write(fd, content.encode("utf-8"))
        os.fsync(fd)
    finally:
        os.close(fd)
    os.replace(tmp, md_path)


# ---------- ollama polish ----------

OLLAMA_HOST = os.environ.get("OLLAMA_HOST", "http://127.0.0.1:11434")


# Streaming polish prompt: returns SMALL edit operations only, NOT a rewrite.
# Output tokens scale with edit count, not transcript length -- typically
# 5-10x fewer tokens than rewriting the window. Each edit MUST be local.
STREAMING_POLISH_PROMPT = """\
You correct meeting transcripts by emitting SMALL LOCAL edits.

Output format: one edit per line, no other text. Each edit is one of:
  SUB "short phrase" => "short replacement"
  INS_AFTER "anchor word" => "."
  CAP "word"

Hard rules:
- Each "SUB" must be SHORT: at most 6 words on each side. NEVER quote a whole sentence.
- Each edit fixes ONE thing. If you would write a long SUB, break it into multiple short SUBs and INS_AFTERs.
- The "old text" must appear LITERALLY (case-sensitive) somewhere in the input.
- A SUB must PRESERVE every content word from the old text in the new text.
  You may only DROP filler words: um, uh, like (only when sentence-leading).
  You may NOT drop nouns, verbs, names, or numbers.
- If nothing to fix, output exactly: NONE
- Do NOT explain, do NOT add prose, do NOT use markdown.

Allowed fixes ONLY:
- Add . ? ! at sentence ends -> use INS_AFTER on the last word.
- Add commas for parseability -> INS_AFTER.
- Capitalize sentence starts and proper nouns you're certain of -> CAP.
- Fix obvious homophones ("their/there", "to/too") -> short SUB.
- Remove a sentence-leading "um, " "uh, " "like, " -> short SUB to "".

Forbidden:
- Rewriting, paraphrasing, summarizing, translating.
- Inventing names, numbers, or facts.
- Editing mid-sentence fillers.
- Long SUBs that quote a sentence or more.
- REFORMATTING numbers, times, dates, codes, units. NEVER turn "1150"
  into "11:50", "two p m" into "2 p.m.", or "v five" into "V5". Numeric
  tokens stay in the form the speaker used.

Example input:
  um yeah we shipped it tuesday it works fine

Example output:
  SUB "um yeah we" => "Yeah, we"
  CAP "tuesday"
  INS_AFTER "tuesday" => ","
  INS_AFTER "fine" => "."
"""

# Constrained prompt informed by community practice + the 2024-2025 GER literature.
# Negative constraints reduce hallucination on rare words; positive examples
# anchor what to fix. Glossary is appended by polish_transcript().
POLISH_SYSTEM_PROMPT = """\
You are an editor cleaning up a speech-to-text meeting transcript.

Apply ONLY these changes:
- Add or correct sentence-ending punctuation: . ? !
- Add commas where a sentence is genuinely hard to parse without one.
- Capitalize the first letter of every sentence and proper nouns you are
  certain of (people's names already mentioned, common product names).
- Fix obvious homophone or near-homophone errors when context makes the
  intended word unambiguous (e.g. "their" vs "there", "to" vs "too").
- Remove standalone filler words at the start of a sentence ONLY:
  "um, ", "uh, ", "like, ". Leave fillers mid-sentence alone.

DO NOT:
- Add, remove, rephrase, summarize, or reorder any other words.
- Invent names, numbers, or facts not in the transcript.
- REFORMAT numbers, times, dates, or codes. If the transcript says "1150
  Eastern", output "1150 Eastern" — do NOT change to "11:50". If it says
  "two p m", output "two p m" — do NOT change to "2 p.m." or "2:00 PM".
  Keep the speaker's original spoken form for ALL numeric tokens.
- DROP any proper noun, number, place name, time reference, or unit. If
  it's in the input, it MUST be in the output, in the same position.
- "Improve" the writing style or tone.
- Combine or split sentences except where punctuation is added.
- Translate or change the language.

If you are unsure whether to change something, leave it as-is.
Output the corrected transcript verbatim, nothing else: no preamble, no
"Here is the corrected transcript", no quote marks around it."""


def ollama_chat(model: str, messages: list[dict], stream: bool = False,
                timeout: int = 600, num_predict: int | None = None) -> str:
    """Call Ollama /api/chat. Returns concatenated assistant content."""
    import urllib.request
    import urllib.error
    options: dict = {"temperature": 0.0, "num_ctx": 32768}
    if num_predict is not None:
        options["num_predict"] = int(num_predict)
    payload = json.dumps({
        "model": model,
        "messages": messages,
        "stream": stream,
        # Disable thinking-mode reasoning for fixup tasks. With it on,
        # gemma4 burns the entire num_predict budget on reasoning that we
        # never see, producing empty output. For structured-edit-extraction
        # this is pure overhead.
        "think": False,
        "options": options,
    }).encode("utf-8")
    req = urllib.request.Request(
        f"{OLLAMA_HOST}/api/chat",
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            if not stream:
                data = json.loads(resp.read().decode("utf-8"))
                return (data.get("message") or {}).get("content", "")
            out = []
            for line in resp:
                if not line.strip():
                    continue
                obj = json.loads(line.decode("utf-8"))
                msg = obj.get("message") or {}
                if "content" in msg:
                    out.append(msg["content"])
                if obj.get("done"):
                    break
            return "".join(out)
    except urllib.error.URLError as e:
        raise RuntimeError(f"ollama unreachable at {OLLAMA_HOST}: {e}") from e


def chunk_text(text: str, max_chars: int = 6000, overlap: int = 200) -> list[str]:
    """Split text on sentence boundaries with small overlap so context bleeds across chunks."""
    text = text.strip()
    if len(text) <= max_chars:
        return [text]
    chunks: list[str] = []
    i = 0
    n = len(text)
    while i < n:
        end = min(i + max_chars, n)
        if end < n:
            # back off to a sentence boundary
            for sep in (". ", "? ", "! ", "\n\n"):
                k = text.rfind(sep, i, end)
                if k != -1 and k > i + max_chars // 2:
                    end = k + len(sep)
                    break
        chunks.append(text[i:end])
        if end >= n:
            break
        i = max(end - overlap, i + 1)
    return chunks


def polish_transcript(text: str, model: str, glossary: list[str] | None = None,
                      progress: bool = True) -> str:
    """Polish a raw transcript via Ollama. Returns the cleaned text."""
    glossary_block = ""
    if glossary:
        glossary_block = (
            "\n\nNamed-entity glossary (these spellings are correct, prefer "
            "them when phonetically close):\n- " + "\n- ".join(glossary)
        )
    chunks = chunk_text(text)
    out: list[str] = []
    for i, c in enumerate(chunks, 1):
        if progress:
            sys.stderr.write(f"\rpolishing chunk {i}/{len(chunks)} ...")
            sys.stderr.flush()
        messages = [
            {"role": "system", "content": POLISH_SYSTEM_PROMPT + glossary_block},
            {"role": "user", "content": c},
        ]
        cleaned = ollama_chat(model, messages, stream=False).strip()
        # Defensive: model occasionally adds wrapping quotes despite instructions.
        if (cleaned.startswith('"') and cleaned.endswith('"')) or \
           (cleaned.startswith("```") and cleaned.endswith("```")):
            cleaned = cleaned.strip('"').strip("`").strip()
        out.append(cleaned)
    if progress:
        sys.stderr.write(" done\n")
    return "\n\n".join(out)


def cmd_polish(args) -> int:
    src = Path(args.input).expanduser().resolve()
    if not src.exists():
        print(f"input not found: {src}", file=sys.stderr)
        return 1

    raw = src.read_text(encoding="utf-8")

    # If the file has frontmatter / header lines, strip them so the LLM sees
    # only the transcript body.
    body = strip_meta_lines(raw)

    glossary: list[str] = []
    if args.glossary:
        # Glossary is optional. The default path is ~/recordings/.glossary.txt
        # which often doesn't exist; treat missing as empty rather than crash.
        glossary_path = Path(args.glossary).expanduser()
        if glossary_path.exists():
            glossary = [
                line.strip() for line in
                glossary_path.read_text().splitlines()
                if line.strip() and not line.startswith("#")
            ]

    print(f"input:  {src} ({len(body)} chars)", file=sys.stderr)
    print(f"model:  {args.model}", file=sys.stderr)
    print(f"chunks: {len(chunk_text(body))}", file=sys.stderr)
    if glossary:
        print(f"glossary: {len(glossary)} entries", file=sys.stderr)

    cleaned = polish_transcript(body, args.model, glossary=glossary)

    out_path = (
        Path(args.output).expanduser() if args.output
        else src.with_name(src.stem + ".polished" + src.suffix)
    )
    header = (
        f"<!-- polished by {args.model} on "
        f"{datetime.now().strftime('%Y-%m-%d %H:%M:%S')} from {src.name} -->\n\n"
    )
    out_path.write_text(header + cleaned + "\n", encoding="utf-8")
    print(f"\noutput: {out_path}", file=sys.stderr)
    return 0


def strip_meta_lines(raw: str) -> str:
    """Remove .txt/.md header banners so polish/summary runs on transcript only.

    Strips:
    - YAML frontmatter (between --- markers)
    - Single-line `# meeting-record` banner-style headers
    - HTML comments (one-liner)
    - Single-paragraph italic meta lines (`_..._`) -- our offline.md and
      summary.md wrap meta with these; unstripped, they leak into the
      summary's "transcript content" view.
    - Markdown section headers `## ...` and `# <name>` titles
    """
    lines = raw.splitlines()
    out = []
    in_frontmatter = False
    for ln in lines:
        s = ln.strip()
        if s == "---":
            in_frontmatter = not in_frontmatter
            continue
        if in_frontmatter:
            continue
        if not s:
            out.append(ln)
            continue
        if ln.startswith("# ") and (":" in ln or ln.strip() == "# meeting-record"):
            continue  # banner header
        if s.startswith("<!--") and s.endswith("-->"):
            continue
        # Italic-only meta line: `_text_` or `_text..._`. Real transcript
        # paragraphs almost never start AND end with `_`.
        if s.startswith("_") and s.endswith("_") and len(s) > 2:
            continue
        # Markdown headers: ## Foo, ### Bar (we use these as structural in
        # offline.md). Don't pass to LLM as transcript content.
        if s.startswith("## ") or s.startswith("### "):
            continue
        # Plain `# Title` with no colon: likely a section title, not a banner.
        if s.startswith("# ") and ":" not in s:
            continue
        out.append(ln)
    return "\n".join(out).strip()


# ---------- streaming polisher ----------

class StreamingPolisher:
    """Background thread that polishes recently-finalized segments via Ollama.

    Strategy (informed by GER literature + UX research on stable/draft text):

    1. Three-band model:
       - stable: segments older than POLISH_FREEZE_SECONDS, already polished, frozen.
       - window: segments in the last POLISH_FREEZE_SECONDS, eligible to re-polish.
       - draft: parakeet's draft_tokens; never sent to Ollama.

    2. Triggers:
       - >= POLISH_TRIGGER_WORDS new finalized words since last polish, OR
       - >= POLISH_TRIGGER_SECONDS since last polish AND new finalized text, OR
       - a sentence-ending token (. ? !) appeared.

    3. Concurrency:
       - work_queue is size 1: drop intermediate triggers, only most recent matters.
       - main loop never blocks on polish.
       - if polish takes too long the result lands stale and is reconciled by index.

    4. Hallucination guard:
       - reject polish if its word-count ratio vs raw is outside [0.6, 1.5].
       - on rejection, raw is shown unchanged.

    5. Anchor context:
       - we send the previous 1-2 sentences before the window as context-only
         (instructed not to rewrite). LLM sees the antecedent so pronoun and
         capitalization decisions are grounded.
    """

    POLISH_FREEZE_SECONDS = 30.0
    POLISH_TRIGGER_WORDS = 40
    POLISH_TRIGGER_SECONDS = 15.0
    SENTENCE_ENDERS = (".", "?", "!")
    POLISH_TIMEOUT = 12.0
    LENGTH_RATIO_MIN = 0.6
    LENGTH_RATIO_MAX = 1.5

    def __init__(self, state: TranscriptState, model: str,
                 glossary: list[str] | None = None):
        self.state = state
        self.model = model
        self.glossary = glossary or []
        self.work_queue: queue.Queue = queue.Queue(maxsize=1)
        self.thread: threading.Thread | None = None
        self.stop_event = threading.Event()
        self.last_polish_seg_count = 0
        self.last_polish_word_count = 0
        self.last_polish_audio_s = 0.0

    def start(self):
        # Verify Ollama is reachable; if not, run in degraded mode (no polish).
        try:
            import urllib.request
            urllib.request.urlopen(f"{OLLAMA_HOST}/api/tags", timeout=2.0).close()
        except Exception:
            self.state.set_polish_status("unreachable", model=self.model)
            return False
        self.state.set_polish_status("idle", model=self.model)
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()
        return True

    def stop(self):
        self.stop_event.set()
        try:
            self.work_queue.put_nowait(None)
        except queue.Full:
            pass
        if self.thread is not None:
            # bounded join so a polish pass in flight can't mutate state after
            # the final .md is written; the daemon thread is reaped at exit.
            self.thread.join(timeout=5)

    def maybe_trigger(self) -> None:
        """Call after each chunk; decides whether to enqueue a polish job.

        Reads state under its lock to get a consistent (segments, audio_s).
        """
        with self.state._lock:
            seg_count = len(self.state.segments)
            audio_s = self.state.audio_seconds
            # tail words for sentence-ender detection
            tail_text = self.state.segments[-1]["text"] if self.state.segments else ""
        if seg_count <= self.last_polish_seg_count:
            return  # nothing new
        new_segs = seg_count - self.last_polish_seg_count
        words_added = sum(1 for _ in tail_text.split()) * new_segs  # cheap upper-bound
        time_since = audio_s - self.last_polish_audio_s
        ends_sentence = tail_text.rstrip().endswith(self.SENTENCE_ENDERS)
        if not (
            words_added >= self.POLISH_TRIGGER_WORDS
            or (time_since >= self.POLISH_TRIGGER_SECONDS and new_segs > 0)
            or ends_sentence
        ):
            return
        # Coalesce: if the queue already has a pending job, drop it; the new
        # snapshot subsumes it. queue maxsize=1 makes this naturally.
        try:
            self.work_queue.put_nowait("trigger")
        except queue.Full:
            pass

    def _run(self):
        while not self.stop_event.is_set():
            try:
                item = self.work_queue.get(timeout=0.5)
            except queue.Empty:
                continue
            if item is None or self.stop_event.is_set():
                return
            try:
                self._do_polish_pass()
            except Exception as e:
                # Polish failures are non-fatal; log to state warning.
                self.state.set_polish_status("idle")
                # don't spam the warning; record only changes in failure shape
                pass

    def _do_polish_pass(self):
        # Snapshot under lock
        with self.state._lock:
            segments = list(self.state.segments)
            audio_s = self.state.audio_seconds

        if not segments:
            return

        # Find the window: segments whose t >= audio_s - FREEZE.
        cutoff = audio_s - self.POLISH_FREEZE_SECONDS
        window_start = 0
        for i, s in enumerate(segments):
            if s["t"] >= cutoff:
                window_start = i
                break
        else:
            window_start = self.last_polish_seg_count

        if window_start >= len(segments):
            return

        # Pin the window's end index NOW. The main thread will keep appending
        # segments during the Ollama call; if we used len(self.segments) at
        # commit time, those late-arrivals would be silently consumed by this
        # polished block when the view collapses raw_start..raw_end.
        window_end = len(segments)

        anchor_segs = segments[max(0, window_start - 4):window_start]
        anchor_text = " ".join(s["text"].strip() for s in anchor_segs).strip()
        window_text = " ".join(s["text"].strip() for s in segments[window_start:window_end]).strip()

        if not window_text or len(window_text) < 30:
            return

        self.state.set_polish_status("running")

        glossary_block = ""
        if self.glossary:
            glossary_block = (
                "\n\nNamed-entity glossary (use these spellings exactly, prefer "
                "them when phonetically close):\n- "
                + "\n- ".join(self.glossary)
            )

        anchor_block = ""
        if anchor_text:
            anchor_block = (
                f"\n\nContext from the prior sentences (do NOT edit; for "
                f"capitalization/pronoun grounding only):\n« {anchor_text[-500:]} »"
            )

        # num_predict caps output: ~4 tokens per edit line × at most ~50 edits = 200 tokens.
        # Far below rewriting the entire window.
        max_predict = max(64, min(400, len(window_text) // 8))

        messages = [
            {"role": "system",
             "content": STREAMING_POLISH_PROMPT + anchor_block + glossary_block},
            {"role": "user", "content": window_text},
        ]

        try:
            raw_edits = ollama_chat(
                self.model, messages, stream=False,
                timeout=int(self.POLISH_TIMEOUT),
                num_predict=max_predict,
            )
        except Exception:
            self.state.set_polish_status("unreachable")
            return

        edits = parse_edits(raw_edits)
        if os.environ.get("MEETING_POLISH_DEBUG"):
            sys.stderr.write(
                f"\n[polish] window={len(window_text)} chars, "
                f"raw_response={raw_edits[:200]!r}, parsed={len(edits)} edits\n"
            )
        if not edits:
            self.state.set_polish_status("idle")
            self.last_polish_seg_count = len(segments)
            self.last_polish_audio_s = audio_s
            return

        # Defenses on SUB edits:
        # 1. drop any SUB > ~10 words on either side (rewrite-disguised-as-edit).
        # 2. drop any SUB that DROPS content words. We allow filler removal
        #    ("um, ", "uh, ", "like, ") explicitly; otherwise the replacement
        #    must contain every content word from the find. This catches the
        #    "On them" replacing "on um they se em" case.
        FILLERS = {"um", "uh", "like", "you", "know", "i", "mean", "so",
                   "well", "right", "yeah", "ok", "okay"}
        kept = []
        for op, find, repl in edits:
            if op == "SUB":
                find_words = find.split()
                repl_words = repl.split()
                if len(find_words) > 10 or len(repl_words) > 12:
                    continue
                # Check word-preservation: every non-filler word in find that
                # isn't trivially cased-out must be in repl. Allow case-insensitive
                # match for words.
                # Punctuation- and hyphen-tolerant word-preservation check.
                # We want to reject "on um they se em" -> "On them" (drops "se em")
                # but allow "self aware" -> "self-aware" (hyphenation fix).
                # Strategy: treat hyphens as soft separators on the replacement
                # side so a bare word in find matches as a hyphen-bordered token.
                find_lc = [w.lower().strip(",.;:!?\"'") for w in find_words]
                # Replace common joiners with spaces, then check membership.
                normalized = " ".join(
                    w.lower().strip(",.;:!?\"'") for w in repl_words
                ).replace("-", " ").replace("/", " ")
                repl_lc = " " + normalized + " "
                dropped = [
                    w for w in find_lc
                    if w and w not in FILLERS and (" " + w + " ") not in repl_lc
                ]
                if dropped:
                    continue
            kept.append((op, find, repl))
        edits = kept
        if not edits:
            self.state.set_polish_status("idle")
            self.last_polish_seg_count = len(segments)
            self.last_polish_audio_s = audio_s
            return

        # Defense: cap edit count. Hundreds of operations = rewrite in disguise.
        if len(edits) > 60:
            self.state.set_polish_status("idle")
            return

        cleaned, applied = apply_edits(window_text, edits)

        # Length-ratio guard against pathological deletions/insertions.
        raw_words = len(window_text.split())
        cleaned_words = len(cleaned.split())
        if raw_words > 0:
            ratio = cleaned_words / raw_words
            if ratio < self.LENGTH_RATIO_MIN or ratio > self.LENGTH_RATIO_MAX:
                self.state.set_polish_status("idle")
                return

        if applied == 0:
            self.state.set_polish_status("idle")
            self.last_polish_seg_count = len(segments)
            self.last_polish_audio_s = audio_s
            return

        if os.environ.get("MEETING_POLISH_DEBUG"):
            sys.stderr.write(
                f"\n[polish] window={len(window_text)} chars, "
                f"{len(edits)} edits, {applied} applied, "
                f"raw_words={raw_words} -> {cleaned_words}\n"
            )
            for op, find, repl in edits[:8]:
                sys.stderr.write(f"  {op} {find!r} => {repl!r}\n")

        self.state.replace_polished_window(
            window_start, window_end, cleaned, window_text,
        )
        self.last_polish_seg_count = window_end
        self.last_polish_audio_s = audio_s
        self.state.set_polish_status("idle")


def load_glossary(path: Path) -> list[str]:
    if not path.exists():
        return []
    out = []
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line and not line.startswith("#"):
            out.append(line)
    return out


# Edit-format parsing + application. Format:
#   SUB "<find>" => "<replace>"
#   INS_AFTER "<anchor>" => "<text>"
#   CAP "<word>"
# Quoted strings may contain escaped quotes (\") and newlines (\n).
_EDIT_LINE_RE = re.compile(
    r'^\s*(SUB|INS_AFTER|CAP)\s+"((?:\\.|[^"\\])*)"'
    r'(?:\s+=>\s+"((?:\\.|[^"\\])*)")?\s*$'
)


def _unescape(s: str) -> str:
    return s.replace('\\"', '"').replace("\\n", "\n").replace("\\\\", "\\")


def parse_edits(raw: str) -> list[tuple[str, str, str]]:
    """Parse edit-script output into (op, find, replace_or_empty) tuples.

    Lines that don't match the grammar are dropped silently. NONE = no edits.
    """
    out: list[tuple[str, str, str]] = []
    for line in raw.splitlines():
        line = line.strip()
        if not line or line.upper() == "NONE":
            continue
        m = _EDIT_LINE_RE.match(line)
        if not m:
            continue
        op, a, b = m.group(1), _unescape(m.group(2)), _unescape(m.group(3) or "")
        out.append((op, a, b))
    return out


def _find_after(out: str, needle: str, cursor: int, case_insensitive: bool) -> int:
    """Find `needle` in `out` at or after `cursor`. No fallback to earlier
    positions: that risk silently lands punctuation on the wrong occurrence
    (e.g. two INS_AFTER "users" both targeting the first occurrence would
    end up double-stacking on a single anchor). Drop the edit instead.
    """
    if case_insensitive:
        return out.lower().find(needle.lower(), cursor)
    return out.find(needle, cursor)


def apply_edits(text: str, edits: list[tuple[str, str, str]]) -> tuple[str, int]:
    """Apply edits left-to-right with a moving cursor.

    Returns (new_text, applied_count). Edits whose anchor doesn't appear are
    skipped silently. SUB matches case-sensitively; CAP and INS_AFTER match
    case-insensitively because earlier edits may have shifted casing.
    """
    out = text
    cursor = 0
    applied = 0
    for op, find, repl in edits:
        if not find:
            continue
        ci = op in ("CAP", "INS_AFTER")
        idx = _find_after(out, find, cursor, ci)
        if idx < 0:
            continue
        actual = out[idx:idx + len(find)]
        if op == "SUB":
            if actual != find:
                continue
            out = out[:idx] + repl + out[idx + len(find):]
            cursor = idx + len(repl)
            applied += 1
        elif op == "INS_AFTER":
            ins_at = idx + len(find)
            out = out[:ins_at] + repl + out[ins_at:]
            cursor = ins_at + len(repl)
            applied += 1
        elif op == "CAP":
            ch0 = out[idx]
            cursor = idx + len(find)
            if ch0.islower():
                out = out[:idx] + ch0.upper() + out[idx + 1:]
                applied += 1
            # already-uppercase: no-op, don't inflate the applied count
    return out, applied


# ---------- subcommands ----------

def _dispatch_subcommand(verb: str, rest: list[str]) -> int:
    if verb == "search":
        return cmd_search(rest)
    if verb == "polish":
        return cmd_polish_cli(rest)
    if verb == "redo":
        return cmd_redo(rest)
    if verb == "summary":
        return cmd_summary_cli(rest)
    if verb == "diarize":
        return cmd_diarize_cli(rest)
    if verb == "dictate":
        return cmd_dictate(rest)
    print(f"unknown subcommand: {verb}", file=sys.stderr)
    return 2


# ---------- dictate: push-to-talk -> paste into focused app ----------

DICTATE_SOCK = Path("/tmp") / f"recorder-dictate-{os.getuid()}.sock"


def _dictate_trigger(rest: list[str]) -> int:
    """Send a single command to a running dictate daemon.

    Commands:
      (no flag)            -- toggle: start if idle, stop+transcribe if recording
      --paste              -- after stop+transcribe, paste into focused app
      --status             -- print the daemon's current state and exit

    Exits 0 on success, 1 if the daemon isn't running, 2 on protocol error.
    """
    p = argparse.ArgumentParser(prog="recorder dictate trigger")
    p.add_argument("--paste", action="store_true",
                   help="after transcription completes, paste into focused app")
    p.add_argument("--status", action="store_true",
                   help="print current daemon state and exit")
    args = p.parse_args(rest)

    if not DICTATE_SOCK.exists():
        print(
            f"dictate daemon not running. start with:\n"
            f"  recorder dictate --daemon",
            file=sys.stderr,
        )
        return 1

    import socket as _sock
    cmd = "status" if args.status else ("toggle:paste" if args.paste else "toggle")
    try:
        s = _sock.socket(_sock.AF_UNIX, _sock.SOCK_STREAM)
        s.settimeout(2.0)
        s.connect(str(DICTATE_SOCK))
        s.sendall((cmd + "\n").encode("utf-8"))
        # Read until close. Daemon writes one line of status text.
        buf = b""
        while True:
            chunk = s.recv(4096)
            if not chunk:
                break
            buf += chunk
            if len(buf) > 4096:
                break
        s.close()
        out = buf.decode("utf-8", errors="replace").strip()
        if out:
            print(out)
        return 0
    except (ConnectionRefusedError, FileNotFoundError):
        print("dictate daemon socket not accepting; is it running?",
              file=sys.stderr)
        return 1
    except Exception as e:
        print(f"trigger failed: {e}", file=sys.stderr)
        return 2


def _dictate_daemon(args) -> int:
    """Run as a long-running daemon. Loads parakeet once, then services
    `toggle` and `toggle:paste` commands over a unix socket. Each toggle
    flips between idle (waiting) and recording (capturing); the second
    toggle stops, transcribes, optionally polishes, copies to clipboard,
    and (if `:paste`) types the result via osascript.

    Why a socket and not a signal: signals can't carry the `paste` flag
    cleanly, and a socket lets `trigger` get back a status message.
    Why pbcopy + osascript instead of an accessibility-API typing path:
    no extra deps, works in any focused field (incl. browsers, terminals).
    """
    import socket as _sock
    import threading

    if DICTATE_SOCK.exists():
        # Stale socket from a crashed daemon? Try to claim it.
        try:
            DICTATE_SOCK.unlink()
        except Exception:
            print(f"socket {DICTATE_SOCK} exists and can't be removed",
                  file=sys.stderr)
            return 1

    print(f"loading {args.model} ...", file=sys.stderr, flush=True)
    import mlx.core as mx
    from parakeet_mlx import from_pretrained
    model = from_pretrained(args.model)

    out_dir = Path(os.environ.get(
        "MEETING_DIR", str(Path.home() / "recordings")))
    if args.save:
        out_dir.mkdir(parents=True, exist_ok=True)

    state_lock = threading.Lock()
    state: dict = {
        "phase": "idle",       # idle | recording
        "ffmpeg": None,
        "samples_buf": None,
        "stop_event": None,
        "drain_thread": None,
        "started_at": 0.0,
    }

    def start_recording() -> str:
        with state_lock:
            if state["phase"] != "idle":
                return "already recording"
            samples_buf = bytearray()
            stop_event = threading.Event()
            cmd = [
                "ffmpeg", "-hide_banner", "-loglevel", "error",
                "-f", "avfoundation", "-i", args.device,
                "-ac", "1", "-ar", str(SAMPLE_RATE),
                "-c:a", "flac", "-flush_packets", "1",
                "-y", "/tmp/_dictate_daemon.flac",
                "-ac", "1", "-ar", str(SAMPLE_RATE),
                "-f", "f32le", "-c:a", "pcm_f32le",
                "pipe:1",
            ]
            ff = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                  stderr=subprocess.DEVNULL)

            def drain():
                while not stop_event.is_set():
                    chunk = ff.stdout.read(CHUNK_BYTES)
                    if not chunk:
                        break
                    samples_buf.extend(chunk)

            t = threading.Thread(target=drain, daemon=True)
            t.start()
            state["phase"] = "recording"
            state["ffmpeg"] = ff
            state["samples_buf"] = samples_buf
            state["stop_event"] = stop_event
            state["drain_thread"] = t
            state["started_at"] = time.time()
            return "● recording"

    def stop_and_transcribe(paste: bool) -> str:
        with state_lock:
            if state["phase"] != "recording":
                return "not recording"
            ff = state["ffmpeg"]
            samples_buf = state["samples_buf"]
            stop_event = state["stop_event"]
            elapsed = time.time() - state["started_at"]
            stop_event.set()
            ff.send_signal(signal.SIGINT)
            try:
                ff.wait(timeout=3)
            except subprocess.TimeoutExpired:
                ff.kill()
            state["phase"] = "idle"
            state["ffmpeg"] = None

        if not samples_buf:
            return "○ no audio captured"

        samples = np.frombuffer(bytes(samples_buf), dtype=np.float32)
        audio_s = len(samples) / SAMPLE_RATE
        tmp_wav = Path("/tmp") / f"_dictate_daemon_{os.getpid()}.wav"
        try:
            import soundfile as sf
            sf.write(str(tmp_wav), samples, SAMPLE_RATE)
            result = model.transcribe(str(tmp_wav))
        except Exception as e:
            return f"○ transcribe failed: {e}"
        finally:
            tmp_wav.unlink(missing_ok=True)

        text = (result.text or "").strip()
        if not text:
            return f"○ empty transcript ({audio_s:.1f}s)"

        if args.polish:
            try:
                edits = ollama_chat(
                    args.polish_model,
                    [
                        {"role": "system", "content": STREAMING_POLISH_PROMPT},
                        {"role": "user", "content": text},
                    ],
                    stream=False, timeout=15, num_predict=300,
                )
                parsed = parse_edits(edits)
                if parsed:
                    polished, applied = apply_edits(text, parsed)
                    if applied > 0:
                        text = polished
            except Exception:
                pass

        if not args.no_clipboard:
            try:
                subprocess.run(
                    ["pbcopy"], input=text.encode("utf-8"),
                    timeout=2, check=False,
                )
            except Exception:
                pass

        if paste:
            # Use AppleScript to keystroke the clipboard contents into the
            # frontmost app's focused field. Quoted heredoc so we don't have
            # to escape the literal text.
            try:
                subprocess.run(
                    ["osascript", "-e",
                     'tell application "System Events" to keystroke (the clipboard)'],
                    timeout=10, check=False,
                )
            except Exception as e:
                return f"✓ {len(text.split())} words ({elapsed:.1f}s) — paste failed: {e}"

        if args.save:
            ts = datetime.now().strftime("%Y%m%d-%H%M%S")
            (out_dir / f"dict-{ts}.txt").write_text(text + "\n", encoding="utf-8")

        return f"✓ {len(text.split())} words ({elapsed:.1f}s){' → pasted' if paste else ''}"

    # Listen on the unix socket
    srv = _sock.socket(_sock.AF_UNIX, _sock.SOCK_STREAM)
    srv.bind(str(DICTATE_SOCK))
    DICTATE_SOCK.chmod(0o600)  # user-only
    srv.listen(4)

    def cleanup(*_):
        try:
            srv.close()
        finally:
            if DICTATE_SOCK.exists():
                DICTATE_SOCK.unlink()
        sys.exit(0)

    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)

    print(f"daemon ready (socket: {DICTATE_SOCK})", file=sys.stderr)
    print(
        "trigger with:\n"
        "  recorder dictate trigger             # toggle, copy to clipboard\n"
        "  recorder dictate trigger --paste     # toggle, also paste\n"
        "  recorder dictate trigger --status    # show current state\n"
        "ctrl-c to stop daemon.",
        file=sys.stderr, flush=True,
    )

    while True:
        try:
            conn, _ = srv.accept()
        except OSError:
            break
        try:
            cmd_bytes = b""
            conn.settimeout(2.0)
            while not cmd_bytes.endswith(b"\n") and len(cmd_bytes) < 256:
                chunk = conn.recv(64)
                if not chunk:
                    break
                cmd_bytes += chunk
            cmd = cmd_bytes.decode("utf-8", errors="replace").strip()

            if cmd == "status":
                with state_lock:
                    phase = state["phase"]
                    elapsed = time.time() - state["started_at"] if phase == "recording" else 0.0
                msg = f"phase={phase}" + (f" elapsed={elapsed:.1f}s" if phase == "recording" else "")
            elif cmd in ("toggle", "toggle:paste"):
                paste = (cmd == "toggle:paste")
                with state_lock:
                    cur_phase = state["phase"]
                if cur_phase == "idle":
                    msg = start_recording()
                else:
                    msg = stop_and_transcribe(paste=paste)
            else:
                msg = f"unknown command: {cmd!r}"

            conn.sendall((msg + "\n").encode("utf-8"))
        except Exception as e:
            try:
                conn.sendall(f"error: {e}\n".encode("utf-8"))
            except Exception:
                pass
        finally:
            try:
                conn.close()
            except Exception:
                pass

    cleanup()
    return 0


def cmd_dictate(rest: list[str]) -> int:
    """Push-to-talk dictation.

    Three modes:
      recorder dictate                    # interactive (Enter toggles)
      recorder dictate --daemon           # long-running, listens on unix socket
      recorder dictate trigger [--paste]  # send start/stop to a running daemon

    For SuperWhisper-class global-hotkey UX:
      1. Run `recorder dictate --daemon` (e.g. via launchd plist, see README)
      2. Bind a hotkey in macOS Shortcuts.app to run `recorder dictate trigger --paste`
      3. Press hotkey → records → press again → transcribes → pastes into focused app
    """
    # Sub-verb: `dictate trigger ...` is a thin client.
    if rest and rest[0] == "trigger":
        return _dictate_trigger(rest[1:])

    p = argparse.ArgumentParser(prog="recorder dictate")
    p.add_argument("--device", default=os.environ.get("MEETING_DEVICE", ":0"))
    p.add_argument("--model", default=os.environ.get(
        "PARAKEET_MODEL", "mlx-community/parakeet-tdt-0.6b-v3"))
    p.add_argument("--no-clipboard", action="store_true",
                   help="don't copy result to clipboard")
    p.add_argument("--polish", action="store_true",
                   help="run gemma4 cleanup on the result before paste")
    p.add_argument("--polish-model",
                   default=os.environ.get("MEETING_POLISH_MODEL", "gemma4:e2b"))
    p.add_argument("--save", action="store_true",
                   help="save the audio + transcript to ~/recordings/dict-<ts>")
    p.add_argument("--daemon", action="store_true",
                   help="run as a long-running daemon listening on a unix socket; "
                        "trigger record cycles via `recorder dictate trigger`")
    args = p.parse_args(rest)

    if args.daemon:
        return _dictate_daemon(args)

    print(f"loading {args.model} ...", file=sys.stderr, flush=True)
    import mlx.core as mx
    from parakeet_mlx import from_pretrained
    model = from_pretrained(args.model)
    print("ready. press Enter to start, Enter again to stop.", file=sys.stderr)

    out_dir = Path(os.environ.get(
        "MEETING_DIR", str(Path.home() / "recordings")))
    name = "dict-" + datetime.now().strftime("%Y%m%d-%H%M%S")
    flac_path = out_dir / f"{name}.flac"
    if args.save:
        out_dir.mkdir(parents=True, exist_ok=True)
        print(f"saving -> {flac_path}", file=sys.stderr)

    while True:
        try:
            input()  # block until Enter
        except (EOFError, KeyboardInterrupt):
            print("", file=sys.stderr)
            return 0

        # Capture audio while user holds the floor (until next Enter).
        cmd = [
            "ffmpeg", "-hide_banner", "-loglevel", "error",
            "-f", "avfoundation", "-i", args.device,
            "-ac", "1", "-ar", str(SAMPLE_RATE),
            "-c:a", "flac", "-flush_packets", "1",
            "-y", str(flac_path) if args.save else "/tmp/_dictate.flac",
            "-ac", "1", "-ar", str(SAMPLE_RATE),
            "-f", "f32le", "-c:a", "pcm_f32le",
            "pipe:1",
        ]
        ff = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                              stderr=subprocess.DEVNULL)
        print("● recording (press Enter to stop)", file=sys.stderr)
        samples_buf = bytearray()
        # Drain ffmpeg in a thread; on Enter, SIGINT it.
        import threading
        stop_event = threading.Event()

        def drain():
            while not stop_event.is_set():
                chunk = ff.stdout.read(CHUNK_BYTES)
                if not chunk:
                    break
                samples_buf.extend(chunk)
        t = threading.Thread(target=drain, daemon=True)
        t.start()
        try:
            input()
        except (EOFError, KeyboardInterrupt):
            stop_event.set()
            ff.send_signal(signal.SIGINT)
            ff.wait(timeout=3)
            return 0
        stop_event.set()
        ff.send_signal(signal.SIGINT)
        try:
            ff.wait(timeout=3)
        except subprocess.TimeoutExpired:
            ff.kill()

        # Transcribe in one shot (offline, full-attention).
        if not samples_buf:
            print("no audio captured", file=sys.stderr)
            continue
        samples = np.frombuffer(bytes(samples_buf), dtype=np.float32)
        audio_s = len(samples) / SAMPLE_RATE
        print(f"○ transcribing ({audio_s:.1f}s) ...", file=sys.stderr)
        t0 = time.time()
        tmp_wav = Path("/tmp") / f"_dictate_{os.getpid()}.wav"
        try:
            # Pass numpy directly via mx; parakeet's transcribe wants a path
            # or array. Write a tiny WAV to /tmp and call transcribe.
            import soundfile as sf
            sf.write(str(tmp_wav), samples, SAMPLE_RATE)
            result = model.transcribe(str(tmp_wav))
        except Exception as e:
            print(f"transcribe failed: {e}", file=sys.stderr)
            continue
        finally:
            tmp_wav.unlink(missing_ok=True)
        text = (result.text or "").strip()
        elapsed = time.time() - t0

        if args.polish and text:
            try:
                edits = ollama_chat(
                    args.polish_model,
                    [
                        {"role": "system", "content": STREAMING_POLISH_PROMPT},
                        {"role": "user", "content": text},
                    ],
                    stream=False, timeout=30, num_predict=300,
                )
                parsed = parse_edits(edits)
                if parsed:
                    polished, applied = apply_edits(text, parsed)
                    if applied > 0:
                        text = polished
            except Exception:
                pass  # best-effort

        # Copy to clipboard via pbcopy (macOS).
        if not args.no_clipboard and text:
            try:
                subprocess.run(
                    ["pbcopy"], input=text.encode("utf-8"),
                    timeout=2, check=False,
                )
                print(f"✓ copied to clipboard ({elapsed:.1f}s, {len(text.split())} words)",
                      file=sys.stderr)
            except Exception:
                pass

        # Always print the text to stdout for piping / scripting.
        print(text)
        if args.save:
            txt_path = out_dir / f"{name}.txt"
            txt_path.write_text(text + "\n", encoding="utf-8")
            print(f"  saved -> {txt_path}", file=sys.stderr)
        print("\nready. press Enter for another, Ctrl-C to exit.",
              file=sys.stderr)
        # next iteration uses a fresh name if --save
        if args.save:
            name = "dict-" + datetime.now().strftime("%Y%m%d-%H%M%S")
            flac_path = out_dir / f"{name}.flac"


