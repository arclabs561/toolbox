#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["httpx", "psutil"]
# ///

"""Show local and public IP addresses.

ips        local interfaces + public IP
ips -v     add geo info (city, country, org)
ips -4     force IPv4 for public lookup
ips -6     force IPv6 for public lookup
ips -c     copy public IP to clipboard
ips -p     public IP only (skip local)
"""

import argparse
import contextlib
import platform
import shutil
import socket
import subprocess
import sys
import time

import httpx
import psutil

SKIP_IFACES = {"lo", "lo0", "awdl0", "llw0", "ap1", "anpi0", "anpi1"}

IFACE_LABELS: dict[str, str] = {
    "en0": "wifi",
    "en1": "ethernet",
    "en2": "ethernet",
    "en3": "usb-eth",
    "en4": "usb-eth",
    "eth0": "ethernet",
    "eth1": "ethernet",
    "wlan0": "wifi",
    "wlp0s20f3": "wifi",
    "docker0": "docker",
}

_tty = sys.stdout.isatty()


def dim(text: str) -> str:
    return f"\033[2m{text}\033[0m" if _tty else text


def bold(text: str) -> str:
    return f"\033[1m{text}\033[0m" if _tty else text


def is_ipv4(addr: str) -> bool:
    return "." in addr


def label_for(iface: str) -> str:
    if iface in IFACE_LABELS:
        return IFACE_LABELS[iface]
    for prefix in ("br-", "veth"):
        if iface.startswith(prefix):
            return "docker"
    if iface.startswith(("utun", "tun", "wg")):
        return "vpn"
    if iface.startswith("tailscale"):
        return "tailscale"
    if iface.startswith("wl"):
        return "wifi"
    if iface.startswith("en") or iface.startswith("eth"):
        return "ethernet"
    return iface


# -- default route detection --------------------------------------------------


def default_iface() -> str | None:
    """Return the interface name that carries the default route."""
    try:
        if platform.system() == "Darwin":
            out = subprocess.run(
                ["route", "-n", "get", "default"],
                capture_output=True,
                text=True,
                check=True,
            ).stdout
            for line in out.splitlines():
                if "interface:" in line:
                    return line.split("interface:")[-1].strip()
        else:
            out = subprocess.run(
                ["ip", "route", "get", "1.1.1.1"],
                capture_output=True,
                text=True,
                check=True,
            ).stdout
            for token in out.split():
                if token == "dev":
                    idx = out.split().index("dev")
                    return out.split()[idx + 1]
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


def gateway_ip() -> str | None:
    """Return the default gateway IP."""
    try:
        if platform.system() == "Darwin":
            out = subprocess.run(
                ["route", "-n", "get", "default"],
                capture_output=True,
                text=True,
                check=True,
            ).stdout
            for line in out.splitlines():
                if "gateway:" in line:
                    return line.split("gateway:")[-1].strip()
        else:
            out = subprocess.run(
                ["ip", "route", "show", "default"],
                capture_output=True,
                text=True,
                check=True,
            ).stdout
            parts = out.split()
            if "via" in parts:
                return parts[parts.index("via") + 1]
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


# -- wifi SSID -----------------------------------------------------------------


def wifi_ssid() -> str | None:
    """Return current WiFi SSID, or None."""
    try:
        if platform.system() == "Darwin":
            out = subprocess.run(
                ["ipconfig", "getsummary", "en0"],
                capture_output=True,
                text=True,
                check=True,
            ).stdout
            for line in out.splitlines():
                if "SSID" in line and "BSSID" not in line:
                    return line.split(":", 1)[-1].strip()
        else:
            out = subprocess.run(
                ["iwgetid", "-r"],
                capture_output=True,
                text=True,
                check=True,
            ).stdout.strip()
            return out or None
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return None


# -- local interfaces via psutil -----------------------------------------------


def local_ips(active_iface: str | None) -> list[tuple[str, str, str, bool]]:
    """Return (interface, label, addr, is_default) tuples."""
    addrs = psutil.net_if_addrs()
    stats = psutil.net_if_stats()

    results: list[tuple[str, str, str, bool]] = []
    seen: set[str] = set()

    for iface, addr_list in addrs.items():
        if iface in SKIP_IFACES:
            continue
        st = stats.get(iface)
        if st and not st.isup:
            continue
        for addr in addr_list:
            if addr.family not in (socket.AF_INET, socket.AF_INET6):
                continue
            ip = addr.address.split("%")[0]  # strip zone id
            if ip in ("127.0.0.1", "::1") or ip.startswith("fe80"):
                continue
            if ip in seen:
                continue
            seen.add(ip)
            is_default = iface == active_iface
            results.append((iface, label_for(iface), ip, is_default))

    results.sort(key=lambda r: (not r[3], r[1], not is_ipv4(r[2])))
    return results


# -- public IP -----------------------------------------------------------------

PUBLIC_ENDPOINTS = [
    "https://icanhazip.com",
    "https://wtfismyip.com/text",
    "https://api.ipify.org",
]


def public_ip(client: httpx.Client) -> tuple[str, int]:
    """Return (ip, latency_ms). Tries multiple endpoints."""
    for url in PUBLIC_ENDPOINTS:
        try:
            t0 = time.monotonic()
            resp = client.get(url)
            ms = int((time.monotonic() - t0) * 1000)
            ip = resp.text.strip()
            if ip:
                return ip, ms
        except httpx.HTTPError:
            continue
    raise httpx.ConnectError("all endpoints unreachable")


def geo_info(client: httpx.Client, ip: str) -> str:
    geo = client.get(f"https://ipinfo.io/{ip}/json").json()
    parts = [geo.get("city", ""), geo.get("region", ""), geo.get("country", "")]
    location = ", ".join(p for p in parts if p)
    org = geo.get("org", "")
    return f"{location}  {org}".strip()


# -- clipboard -----------------------------------------------------------------


def copy_to_clipboard(text: str) -> bool:
    for cmd in (["pbcopy"], ["xclip", "-selection", "clipboard"], ["xsel", "--clipboard"]):
        if shutil.which(cmd[0]):
            subprocess.run(cmd, input=text.encode(), check=True)
            return True
    if shutil.which("clip.exe"):
        subprocess.run(["clip.exe"], input=text.encode(), check=True)
        return True
    return False


# -- main ----------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(description="Show local and public IPs")
    proto = parser.add_mutually_exclusive_group()
    proto.add_argument("-4", dest="ipv4", action="store_true", help="force IPv4")
    proto.add_argument("-6", dest="ipv6", action="store_true", help="force IPv6")
    parser.add_argument("-v", dest="verbose", action="store_true", help="geo info")
    parser.add_argument("-c", dest="copy", action="store_true", help="copy public IP")
    parser.add_argument("-p", dest="public_only", action="store_true", help="public only")
    args = parser.parse_args()

    # local
    if not args.public_only:
        host = socket.gethostname().removesuffix(".local")
        active = default_iface()
        ssid = wifi_ssid()
        gw = gateway_ip()

        header = host
        if ssid:
            header += f"  {dim(ssid)}"
        print(bold(header))

        for _iface, label, addr, is_default in local_ips(active):
            v = "4" if is_ipv4(addr) else "6"
            marker = "*" if is_default else " "
            print(f"  {marker} {dim(label):<21} {addr}  {dim(v)}")

        if gw:
            print(f"    {dim('gateway'):<21} {dim(gw)}")
        print()

    # public
    transport = None
    if args.ipv4:
        transport = httpx.HTTPTransport(local_address="0.0.0.0")
    elif args.ipv6:
        transport = httpx.HTTPTransport(local_address="::")

    client = httpx.Client(timeout=5, transport=transport) if transport else httpx.Client(timeout=5)

    try:
        pub, latency = public_ip(client)
    except httpx.HTTPError:
        print(f"    {dim('public'):<21} (unreachable)", file=sys.stderr)
        sys.exit(0 if not args.public_only else 1)

    geo = ""
    if args.verbose:
        with contextlib.suppress(httpx.HTTPError):
            geo = geo_info(client, pub)

    latency_str = dim(f"{latency}ms")
    if geo:
        print(f"    {dim('public'):<21} {pub}  {latency_str}  {dim(geo)}")
    else:
        print(f"    {dim('public'):<21} {pub}  {latency_str}")

    if args.copy:
        if copy_to_clipboard(pub):
            print("(copied)", file=sys.stderr)
        else:
            print("(no clipboard tool found)", file=sys.stderr)


if __name__ == "__main__":
    main()
