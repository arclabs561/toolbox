# ---------- main ----------

def main() -> int:
    # Dispatch to subcommands when the first positional arg is one of the
    # reserved verbs. Preserves the simple `recorder <name>` UX while
    # adding `recorder search ...`, `polish ...`, `redo ...`.
    #
    # F1 collision guard: a recording legitimately named "search" / "polish"
    # / "redo" / "summary" must not silently dispatch to the subcommand.
    # Disambiguation: if the user wants a recording with one of these names,
    # they pass `record search` explicitly. Bare `recorder search`
    # always dispatches to subcommand.
    SUBCOMMANDS = {"search", "polish", "redo", "summary", "diarize", "dictate"}
    argv = sys.argv[1:]
    if argv and argv[0] == "record" and len(argv) > 1:
        # explicit recording mode: drop the "record" verb
        argv = argv[1:]
        sys.argv = [sys.argv[0]] + argv
    elif argv and argv[0] in SUBCOMMANDS:
        return _dispatch_subcommand(argv[0], argv[1:])

    p = argparse.ArgumentParser(
        description="Record + transcribe a meeting with parakeet-mlx",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("name", nargs="?", default=None)
    p.add_argument("--device", default=os.environ.get("MEETING_DEVICE", ":0"))
    p.add_argument("--model", default=os.environ.get(
        "PARAKEET_MODEL", "mlx-community/parakeet-tdt-0.6b-v3"))
    p.add_argument("--from-file", default=None)
    p.add_argument("--list-devices", action="store_true")
    p.add_argument("--no-browser", action="store_true",
                   help="don't auto-open the live page")
    p.add_argument("--port", type=int,
                   default=int(os.environ.get("MEETING_PORT", "0")),
                   help="HTTP port (default: ephemeral)")
    p.add_argument("--polish-model",
                   default=os.environ.get("MEETING_POLISH_MODEL", "gemma4:e2b"),
                   help="Ollama model for streaming polish (default: gemma4:e2b)")
    p.add_argument("--polish", action="store_true",
                   help="enable EXPERIMENTAL streaming LLM polish (off by default; "
                        "ordering + concatenation bugs are still being worked out)")
    p.add_argument("--no-offline-pass", action="store_true",
                   help="skip the offline re-pass on the saved FLAC after stop "
                        "(default: re-pass runs, producing higher-quality "
                        "<name>.offline.{md,txt,json})")
    p.add_argument("--diarize", action="store_true",
                   help="after offline pass, run sherpa-onnx pyannote diarization "
                        "to attach speaker labels (writes <name>.diarized.{md,json}). "
                        "Auto-downloads ~35MB of models on first run.")
    p.add_argument("--num-speakers", type=int, default=-1,
                   help="number of speakers to find (default -1 = auto-detect)")
    p.add_argument("--diarize-threshold", type=float, default=0.65,
                   help="speaker-clustering threshold (lower = more speakers; "
                        "default 0.65; 0.5 over-clusters real meetings, 0.7 "
                        "merges similar voices)")
    p.add_argument("--summary", action="store_true",
                   help="after offline pass, run gemma4 to extract summary, "
                        "decisions, and action items (writes <name>.summary.md)")
    p.add_argument("--summary-model",
                   default=os.environ.get("MEETING_SUMMARY_MODEL", "gemma4:latest"),
                   help="Ollama model for post-meeting summary (default: gemma4:latest)")
    p.add_argument("--glossary",
                   default=os.environ.get(
                       "MEETING_GLOSSARY",
                       str(Path.home() / "recordings" / ".glossary.txt"),
                   ),
                   help="glossary file with one named-entity per line")
    args = p.parse_args()

    if args.list_devices:
        return list_devices()

    # Opportunistic system-audio capture: if a BlackHole-containing
    # aggregate device exists and the user didn't pin --device, prefer it.
    args.device = auto_detect_device(
        args.device, env_set=("MEETING_DEVICE" in os.environ)
    )

    out_dir = Path(os.environ.get(
        "MEETING_DIR", str(Path.home() / "recordings")))
    out_dir.mkdir(parents=True, exist_ok=True)

    name = args.name or datetime.now().strftime("%Y%m%d-%H%M%S")
    flac_path = out_dir / f"{name}.flac"
    md_path = out_dir / f"{name}.md"
    txt_path = out_dir / f"{name}.txt"
    log_path = out_dir / f"{name}.log"

    print(f"loading {args.model} ...", file=sys.stderr, flush=True)
    import mlx.core as mx
    from parakeet_mlx import from_pretrained, DecodingConfig, SentenceConfig
    model = from_pretrained(args.model)

    # Sentence config: split finalized output on >0.8s silence OR every 25
    # words OR every 18s of audio. This means raw segments are roughly
    # sentence-shaped before any LLM polish, addressing 80% of the
    # readability gap that polish was reverse-engineering.
    decoding_config = DecodingConfig(
        sentence=SentenceConfig(silence_gap=0.8, max_words=25, max_duration=18.0)
    )

    dev_label = (
        f"file: {args.from_file}" if args.from_file else device_label(args.device)
    )
    started = datetime.now().astimezone()
    started_str = started.strftime("%Y-%m-%d %H:%M:%S %Z")
    meta = {
        "name": name,
        "started": started_str,
        "model": args.model,
        "input": dev_label,
        "audio_file": flac_path.name,
        "md_path": str(md_path),
        "paths": {
            "md": str(md_path),
            "txt": str(txt_path),
            "flac": str(flac_path),
            "log": str(log_path),
        },
    }

    state = TranscriptState(meta)
    state.set_status("starting")

    # Streaming polisher: experimental, opt-in via --polish. When working it
    # produces a cleaned view; when buggy (current state) it can mis-order
    # segments. Off by default until the ordering bugs are resolved.
    polisher: StreamingPolisher | None = None
    if args.polish:
        glossary = load_glossary(Path(args.glossary).expanduser())
        polisher = StreamingPolisher(state, args.polish_model, glossary=glossary)
        if polisher.start():
            print(f"polish -> {args.polish_model} (experimental)"
                  + (f" (glossary: {len(glossary)} entries)" if glossary else ""),
                  file=sys.stderr)
        else:
            print(f"polish -> disabled (ollama unreachable at {OLLAMA_HOST})",
                  file=sys.stderr)
            polisher = None
    else:
        state.set_polish_status("disabled")

    # Web server
    try:
        srv, port, _ = start_server(state, args.port)
    except OSError as e:
        print(f"warning: web server failed to start ({e}); continuing without UI",
              file=sys.stderr)
        srv = None
        port = 0
    url = f"http://127.0.0.1:{port}/" if srv else None

    print(f"audio  -> {flac_path}", file=sys.stderr)
    print(f"text   -> {txt_path}", file=sys.stderr)
    print(f"md     -> {md_path}", file=sys.stderr)
    print(f"log    -> {log_path}", file=sys.stderr)
    print(f"input  -> {dev_label}", file=sys.stderr)
    if url:
        print(f"live   -> {url}", file=sys.stderr)
    print("ctrl-c to stop (twice to abort)", file=sys.stderr, flush=True)
    if url and not args.no_browser:
        # Hand-off to macOS `open` directly: more reliable than webbrowser
        # under Ghostty + complex default-browser setups, and surfaces errors.
        opened = False
        if sys.platform == "darwin":
            try:
                rc = subprocess.run(
                    ["open", url], capture_output=True, text=True, timeout=5
                ).returncode
                opened = rc == 0
            except Exception:
                opened = False
        if not opened:
            try:
                opened = webbrowser.open(url, new=2)
            except Exception:
                opened = False
        if not opened:
            print(f"(could not auto-open browser; visit {url})",
                  file=sys.stderr)

    log_f = open(log_path, "wb")
    cmd = build_ffmpeg_cmd(args.device, args.from_file, flac_path)
    ffmpeg = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=log_f)

    txt_fd = os.open(
        str(txt_path), os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o644)

    # Write txt header up-front
    txt_header = (
        f"# recorder\n"
        f"# name:    {name}\n"
        f"# started: {started_str}\n"
        f"# model:   {args.model}\n"
        f"# input:   {dev_label}\n"
        f"# audio:   {flac_path.name}\n"
        f"\n"
    )
    os.write(txt_fd, txt_header.encode("utf-8"))
    os.fsync(txt_fd)
    write_md_atomic(md_path, render_md(state))

    interrupts = 0

    hard_exiting = False

    def stop(*_):
        nonlocal interrupts, hard_exiting
        interrupts += 1
        if interrupts >= 2 and not hard_exiting:
            hard_exiting = True  # a third ctrl-C must not re-enter this block
            sys.stderr.write("\nhard exit\n")
            try:
                os.fsync(txt_fd)
            except OSError:
                pass  # txt_fd may already be closed by the finally block
            if ffmpeg.poll() is None:
                # ffmpeg already got SIGINT from the terminal; give it a bounded
                # moment to flush the FLAC trailer before forcing it, so even the
                # abort path stays playable.
                ffmpeg.send_signal(signal.SIGINT)
                try:
                    ffmpeg.wait(timeout=2)
                except subprocess.TimeoutExpired:
                    ffmpeg.kill()
            # os._exit skips the finally, so clean up a half-written .md.tmp.
            try:
                os.unlink(str(md_path.with_suffix(md_path.suffix + ".tmp")))
            except OSError:
                pass
            os._exit(130)

    signal.signal(signal.SIGINT, stop)
    signal.signal(signal.SIGTERM, stop)

    start = time.time()
    written = 0
    total_samples = 0
    last_status = 0.0
    next_marker = TIMESTAMP_INTERVAL
    first_audio_warned = False

    try:
        # Streaming knobs (parakeet-mlx). Empirical sweep on the 2-min
        # real-meeting eval clip (m1_2min) vs frozen-offline ground truth:
        #
        #   config                          live WER   notes
        #   ctx=256 d=1  ka=0 (parakeet d.) 19.3%      baseline
        #   ctx=512 d=1  ka=0               20.1%      bigger ctx hurt
        #   ctx=256 d=1  ka=1 (full attn!)  36.5%      "less suitable for streaming"
        #   ctx=256 d=4  ka=0               17.0%      depth helps
        #   ctx=256 d=8  ka=0               13.4%      best — 31% relative improvement
        #   ctx=256 d=12 ka=0               13.4%      saturates at 8
        #
        # depth=N means N encoder layers preserve exact non-streaming
        # computation. parakeet-tdt-0.6b-v3 has ~24 layers; depth=8 is
        # the inflection point. Same wall time, no extra latency.
        ctx = int(os.environ.get("MEETING_CONTEXT_SIZE", "256"))
        depth = int(os.environ.get("MEETING_STREAM_DEPTH", "8"))
        keep_orig = os.environ.get("MEETING_KEEP_ORIGINAL_ATTENTION", "0") == "1"
        with model.transcribe_stream(
            decoding_config=decoding_config,
            context_size=(ctx, ctx),
            depth=depth,
            keep_original_attention=keep_orig,
        ) as tx:
            state.set_status("recording")
            while interrupts == 0 and not state.stop_requested:
                buf = read_exact(ffmpeg.stdout, CHUNK_BYTES)
                if len(buf) < 4:
                    if total_samples == 0 and ffmpeg.poll() not in (None, 0):
                        log_f.flush()
                        try:
                            tail = log_path.read_text(errors="replace").strip().splitlines()[-3:]
                        except Exception:
                            tail = []
                        msg = ("ffmpeg exited before audio arrived. "
                               "last log lines: " + " | ".join(tail))
                        sys.stderr.write("\n" + msg + "\n")
                        state.set_status("stopped", warning=msg)
                    break

                samples_np = np.frombuffer(buf, dtype=np.float32)
                total_samples += len(samples_np)
                audio_s = total_samples / SAMPLE_RATE
                wall_s = time.time() - start

                # Per-chunk peak in dBFS (float32 PCM is in [-1, 1]).
                # 20*log10 of the abs-max sample. Floor at -120 dB so silent
                # chunks don't divide-by-zero.
                if samples_np.size > 0:
                    peak = float(np.abs(samples_np).max())
                    chunk_peak_db = (
                        20.0 * np.log10(peak) if peak > 1e-6 else -120.0
                    )
                else:
                    chunk_peak_db = -120.0

                tx.add_audio(mx.array(samples_np))

                # finalized increments
                finalized = tx.finalized_tokens
                if len(finalized) > written:
                    new_batch = finalized[written:]
                    new_text = "".join(t.text for t in new_batch)
                    # Label with the FIRST new token's start time. Using the
                    # last token's time was a bug: a later batch whose first
                    # token started earlier than a previous batch's last token
                    # would sort BEFORE the previous batch in the rendered .md,
                    # producing scrambled output.
                    seg_t = new_batch[0].start if new_batch else audio_s
                    written = len(finalized)
                    if new_text:
                        os.write(txt_fd, new_text.encode("utf-8"))
                        os.fsync(txt_fd)
                        state.append_finalized(new_text, seg_t)
                        if polisher is not None:
                            polisher.maybe_trigger()

                # 5-min markers
                if audio_s >= next_marker:
                    label = f"[{hms(next_marker)}]"
                    os.write(txt_fd, f"\n\n{label}\n".encode("utf-8"))
                    os.fsync(txt_fd)
                    state.add_marker(next_marker, label)
                    next_marker += TIMESTAMP_INTERVAL

                # User-requested mark via /control/mark
                if state.mark_requested:
                    state.mark_requested = False
                    label = f"[{hms(audio_s)}] ★"
                    os.write(txt_fd, f"\n\n{label}\n".encode("utf-8"))
                    os.fsync(txt_fd)
                    state.add_marker(audio_s, label, user=True)

                # draft + timer + level meter for the live UI.
                # Render draft from draft_tokens ONLY -- tx.result.text is
                # finalized+draft concatenated, so slicing its tail duplicates
                # already-finalized text into the draft block.
                draft_text = "".join(t.text for t in tx.draft_tokens)
                state.set_draft(draft_text, audio_s, wall_s, peak_db=chunk_peak_db)

                # rewrite md after meaningful change (every chunk: cheap)
                write_md_atomic(md_path, render_md(state))

                # warn on no-audio
                now = time.time()
                if (not first_audio_warned and not args.from_file
                        and total_samples == 0
                        and (now - start) > FIRST_AUDIO_DEADLINE):
                    msg = ("no audio in 5s. mic permission likely denied. "
                           "check System Settings > Privacy & Security > Microphone.")
                    sys.stderr.write("\nwarning: " + msg + "\n")
                    state.set_status("recording", warning=msg)
                    first_audio_warned = True

                if now - last_status > 0.5:
                    tail_disp = tx.result.text[-100:].replace("\n", " ")
                    sys.stderr.write(
                        f"\r[{hms(wall_s)} rec {hms(audio_s)}] {tail_disp:<100}")
                    sys.stderr.flush()
                    last_status = now

            # Flush draft tokens
            draft = tx.draft_tokens
            if draft:
                tail_text = "".join(t.text for t in draft)
                if tail_text:
                    os.write(txt_fd, tail_text.encode("utf-8"))
                    os.fsync(txt_fd)
                    state.append_finalized(tail_text, total_samples / SAMPLE_RATE)
            state.set_draft("", total_samples / SAMPLE_RATE, time.time() - start)
            sys.stderr.write("\n")
            sys.stderr.flush()
    finally:
        if ffmpeg.poll() is None:
            ffmpeg.send_signal(signal.SIGINT)
            try:
                ffmpeg.wait(timeout=5)
            except subprocess.TimeoutExpired:
                ffmpeg.kill()
                ffmpeg.wait()

        ended = datetime.now().astimezone()
        ended_str = ended.strftime("%Y-%m-%d %H:%M:%S %Z")
        wall_s = time.time() - start
        audio_s = total_samples / SAMPLE_RATE

        os.write(txt_fd, (
            f"\n\n# ended:   {ended_str}\n"
            f"# duration: {hms(wall_s)} wall, {hms(audio_s)} audio\n"
        ).encode("utf-8"))
        os.fsync(txt_fd)
        os.close(txt_fd)

        state.set_status("stopped")
        write_md_atomic(md_path, render_md(state, ended=ended_str))
        log_f.close()
        if polisher is not None:
            polisher.stop()
        if srv is not None:
            # let the page show "stopped" + final state propagate before shutting down
            time.sleep(2.0)
            srv.shutdown()
            srv.server_close()

    # Offline re-pass on the saved FLAC: full-attention, more accurate.
    # Default ON because the quality jump is large; takes <1m for 1h audio.
    offline_paths = None
    if total_samples > 0 and not args.no_offline_pass and flac_path.exists():
        offline_paths = run_offline_pass(
            flac_path, model, mx, name, started_str, args.model, dev_label,
        )
        # F4 fix: auto-update search index when an offline transcript lands.
        # Best-effort — index failure must not block the recording artifact.
        if offline_paths is not None:
            try:
                _index_after_offline(offline_paths[0], name)
            except Exception as e:
                print(f"search index update skipped: {e}", file=sys.stderr)

    # Diarization: speakers_detected + diarized.md alongside offline.md
    if args.diarize:
        if offline_paths is None:
            if args.no_offline_pass:
                print("diarize skipped: requires --no-offline-pass to be off",
                      file=sys.stderr)
            else:
                print("diarize skipped: no offline transcript available",
                      file=sys.stderr)
        else:
            # F3 (cumulative-flaws): if a stale diarized.md predates the offline
            # pass we just ran, delete it. Otherwise on diarize-failure we'd
            # leave the user with mismatched files.
            stale_diar = flac_path.parent / f"{name}.diarized.md"
            if stale_diar.exists():
                try:
                    if stale_diar.stat().st_mtime < offline_paths[0].stat().st_mtime:
                        stale_diar.unlink()
                        for ext in (".diarized.json",):
                            p = flac_path.parent / f"{name}{ext}"
                            if p.exists():
                                p.unlink()
                except Exception:
                    pass
            try:
                diar_md = run_diarize_pass(
                    flac_path, offline_paths[1], name,
                    num_speakers=args.num_speakers,
                    threshold=args.diarize_threshold,
                )
                # F1 (cumulative-flaws): re-index search with diarized.md so
                # speaker labels become searchable. The diarized text contains
                # the same words plus "**Speaker N:**" prefixes which are useful
                # search keys ("speaker 3" finds Speaker 3's contributions).
                if diar_md is not None:
                    try:
                        _index_after_offline(diar_md, name)
                    except Exception as e:
                        print(f"search index update (diarized) skipped: {e}",
                              file=sys.stderr)
            except Exception as e:
                print(f"diarize FAILED: {e}", file=sys.stderr)

    # Post-meeting summary via Ollama: action items + decisions + 3-sentence summary.
    # F3 guard: --summary requires offline_paths. Warn loudly if user disabled
    # offline pass — silent no-op is the worst UX.
    if args.summary:
        if offline_paths is None:
            if args.no_offline_pass:
                print("summary skipped: --summary requires --no-offline-pass to be off",
                      file=sys.stderr)
            elif total_samples == 0:
                print("summary skipped: no audio captured", file=sys.stderr)
            else:
                print("summary skipped: offline pass produced no transcript",
                      file=sys.stderr)
        else:
            offline_md, offline_json = offline_paths
            try:
                summary_path = run_summary_pass(
                    offline_md, args.summary_model, name, dev_label, started_str,
                )
                print(f"summary -> {summary_path}", file=sys.stderr)
            except Exception as e:
                print(f"summary FAILED: {e}", file=sys.stderr)

    rc = ffmpeg.returncode or 0
    if total_samples == 0:
        print(
            f"warning: no audio captured. check mic permission and {log_path}",
            file=sys.stderr,
        )

    # Trust-calibration: compare live vs offline transcripts and surface
    # a rough quality signal. Computed via Levenshtein-style word-diff so
    # the user sees concretely how much the live UI was off. Skipped if
    # either artifact is missing (e.g. --no-offline-pass).
    if offline_paths is not None:
        try:
            live_text = txt_path.read_text(encoding="utf-8") if txt_path.exists() else ""
            offline_md_p, _ = offline_paths
            offline_text = offline_md_p.read_text(encoding="utf-8") if offline_md_p.exists() else ""

            def _strip_meta(s: str) -> str:
                lines = []
                for ln in s.splitlines():
                    t = ln.strip()
                    if t.startswith("#") or t.startswith("---"):
                        continue
                    if t.startswith("_") and t.endswith("_"):
                        continue
                    lines.append(ln)
                return "\n".join(lines).strip()

            live_words = _strip_meta(live_text).lower().split()
            off_words = _strip_meta(offline_text).lower().split()
            if live_words and off_words:
                # Approximate WER via Python's difflib (no external dep).
                # Treats word lists as sequences and counts edit ops.
                import difflib
                sm = difflib.SequenceMatcher(None, off_words, live_words)
                # 1 - ratio() is roughly Levenshtein-normalized; not WER but
                # close enough for a one-line trust signal.
                live_quality = sm.ratio()
                wer_approx = (1.0 - live_quality) * 100
                print(
                    f"quality: live ≈ {wer_approx:.1f}% different from offline "
                    f"({len(live_words)} vs {len(off_words)} words)",
                    file=sys.stderr,
                )
        except Exception:
            pass  # best-effort

    print(f"done: {md_path}", file=sys.stderr)
    return 0 if rc in (0, -signal.SIGINT, 255) else rc


if __name__ == "__main__":
    raise SystemExit(main())
