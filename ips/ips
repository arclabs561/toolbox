DIAG_TARGET = "example.com"
DIAG_COUNT = 20
DIAG_TIMEOUT = 2.0
SPEED_DURATION = 10
SPEED_PORT = 5201


def dim(text: str) -> str:
    return f"\033[2m{text}\033[0m" if _tty else text


def bold(text: str) -> str:
    return f"\033[1m{text}\033[0m" if _tty else text


